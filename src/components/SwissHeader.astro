---
interface Props {
    currentPage?: string;
}

const { currentPage = "" } = Astro.props;

const navItems = [
    { href: "/", label: "Home", key: "home" },
    { href: "/services/growth/", label: "Services", key: "services" },
    { href: "/ekosistem/", label: "Ekosistem", key: "ekosistem" },
    { href: "/ai-agent/", label: "AI Agent", key: "ai-agent" },
    { href: "/about/", label: "About", key: "about" },
];
---

<!-- Header -->
<header
    class="fixed top-0 w-full z-50 px-6 py-4 md:px-12 md:py-5 flex justify-between items-center bg-gradient-to-b from-background-light/90 to-transparent dark:from-background-dark/90 backdrop-blur-[1px]"
>
    <a
        href="/"
        class="font-display font-extrabold text-xl md:text-2xl tracking-tighter uppercase relative z-10"
    >
        Alpha<span class="text-primary">.</span>
    </a>

    <!-- Desktop Navigation -->
    <nav
        class="hidden md:flex gap-8 text-[10px] md:text-[11px] font-bold uppercase tracking-[0.2em] text-slate-700 dark:text-slate-300"
        aria-label="Main navigation"
    >
        {
            navItems.map((item) => (
                <a
                    href={item.href}
                    aria-current={currentPage === item.key ? "page" : undefined}
                    class:list={[
                        "transition-colors py-1 text-slate-700 dark:text-slate-300",
                        currentPage === item.key
                            ? "text-primary border-b-2 border-primary"
                            : "hover:text-primary",
                    ]}
                >
                    {item.label}
                </a>
            ))
        }
    </nav>

    <!-- Language Toggle ID | EN — desktop -->
    <div id="lang-toggle" class="hidden md:flex items-center gap-1.5 ml-4">
        <a id="lang-id" href="/" class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-sm border transition-colors">ID</a>
        <span class="text-slate-300 text-[10px]">|</span>
        <a id="lang-en" href="/en/" class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-sm border transition-colors">EN</a>
    </div>

    <!-- Mobile Menu Button -->
    <button
        id="mobile-menu-btn"
        class="md:hidden flex items-center justify-center w-11 h-11 text-charcoal dark:text-white -mr-2"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
    </button>
</header>

<!-- Mobile Navigation Overlay -->
<div
    id="mobile-menu"
    class="fixed inset-0 z-40 bg-background-light/95 dark:bg-background-dark/95 backdrop-blur-sm hidden md:hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
    aria-hidden="true"
>
    <button
        id="mobile-menu-close"
        class="absolute top-4 right-4 flex items-center justify-center w-11 h-11 text-charcoal dark:text-white"
        aria-label="Close menu"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
    </button>
    <nav
        class="flex flex-col items-center justify-center h-full gap-2"
        aria-label="Mobile navigation"
    >
        {
            navItems.map((item) => (
                <a
                    href={item.href}
                    aria-current={currentPage === item.key ? "page" : undefined}
                    class:list={[
                        "flex items-center justify-center px-8 py-3 text-lg font-bold uppercase tracking-widest transition-colors",
                        currentPage === item.key
                            ? "text-primary"
                            : "text-charcoal dark:text-white hover:text-primary",
                    ]}
                >
                    {item.label}
                </a>
            ))
        }
        <!-- Mobile Language Toggle -->
        <div class="flex items-center gap-2 mt-4">
            <a id="lang-id-mob" href="/" class="text-sm font-bold uppercase tracking-widest px-4 py-2 rounded border transition-colors">🇮🇩 ID</a>
            <a id="lang-en-mob" href="/en/" class="text-sm font-bold uppercase tracking-widest px-4 py-2 rounded border transition-colors">🇬🇧 EN</a>
        </div>
        <!-- Mobile-only WhatsApp CTA inside nav -->
        <a
            href="https://wa.me/628814802249"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 flex items-center justify-center gap-2 px-8 py-3.5 bg-primary text-white font-bold text-sm uppercase tracking-widest border-2 border-charcoal"
        >
            <span class="material-symbols-outlined text-[18px]">chat</span>
            WhatsApp Us
        </a>
    </nav>
</div>

<script is:inline>
    // Mobile menu
    const menuBtn = document.getElementById("mobile-menu-btn");
    const menuClose = document.getElementById("mobile-menu-close");
    const mobileMenu = document.getElementById("mobile-menu");

    function openMenu() {
        if (!mobileMenu || !menuBtn) return;
        mobileMenu.classList.remove("hidden");
        mobileMenu.removeAttribute("aria-hidden");
        menuBtn.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
    }

    function closeMenu() {
        if (!mobileMenu || !menuBtn) return;
        mobileMenu.classList.add("hidden");
        mobileMenu.setAttribute("aria-hidden", "true");
        menuBtn.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
    }

    if (menuBtn) menuBtn.addEventListener("click", openMenu);
    if (menuClose) menuClose.addEventListener("click", closeMenu);

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && mobileMenu && !mobileMenu.classList.contains("hidden")) {
            closeMenu();
            menuBtn?.focus();
        }
    });

    if (mobileMenu) {
        mobileMenu.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", closeMenu);
        });
    }

    // Language toggle
    (function() {
        const isEN = window.location.pathname.startsWith('/en/') || window.location.pathname === '/en';
        const path = window.location.pathname;

        function enPath(p) { return p.startsWith('/en') ? p : '/en' + (p === '/' ? '' : p); }
        function idPath(p) { return p.replace(/^\/en/, '') || '/'; }

        const activeClass = 'border-primary/40 text-primary bg-primary/5';
        const inactiveClass = 'border-transparent hover:border-primary/30 text-slate-400 hover:text-primary';

        // Desktop toggle
        const idBtn = document.getElementById('lang-id');
        const enBtn = document.getElementById('lang-en');
        if (idBtn && enBtn) {
            idBtn.href = isEN ? idPath(path) : path;
            enBtn.href = isEN ? path : enPath(path);
            if (isEN) {
                enBtn.className = enBtn.className + ' ' + activeClass;
                idBtn.className = idBtn.className + ' ' + inactiveClass;
            } else {
                idBtn.className = idBtn.className + ' ' + activeClass;
                enBtn.className = enBtn.className + ' ' + inactiveClass;
            }
        }

        // Mobile toggle
        const idMob = document.getElementById('lang-id-mob');
        const enMob = document.getElementById('lang-en-mob');
        if (idMob && enMob) {
            idMob.href = isEN ? idPath(path) : path;
            enMob.href = isEN ? path : enPath(path);
            if (isEN) {
                enMob.className = enMob.className + ' border-primary/40 text-primary bg-primary/5';
                idMob.className = idMob.className + ' border-transparent text-slate-400';
            } else {
                idMob.className = idMob.className + ' border-primary/40 text-primary bg-primary/5';
                enMob.className = enMob.className + ' border-transparent text-slate-400';
            }
        }
    })();
</script>
