---
import SwissHeader from "./SwissHeader.astro";
import SwissFooter from "./SwissFooter.astro";
import "../styles/global.css";
import { SITE_URL, SITE_TITLE } from "../consts";

interface Props {
    title: string;
    description?: string;
    currentPage?: string;
    robots?: "index, follow" | "noindex, follow" | "noindex, nofollow";
    /** Absolute or root-relative OG/Twitter image. Falls back to the sitewide default. */
    image?: string;
    /** When present, the page is an Article: emits og:type=article + article:* meta. */
    article?: {
        publishedTime?: string;
        modifiedTime?: string;
    };
}

const { title, description = "Alpha Digital Agency Indonesia — Google Ads, AI & Digital Transformation for Bali Hospitality", currentPage = "", robots = "index, follow", image, article } = Astro.props;
const BUILD_MARKER = "SEO-FIX-2026-06-14-ALPHA";

// GA4 Measurement ID — public by design, safe to hardcode in static HTML.
// import.meta.env.PUBLIC_GA4_ID feeds this at build time when the env var is set
// (CF Pages build environment or local .env); hardcoded fallback ensures the snippet
// is never absent from prerendered HTML even when the env var is not explicitly set.
const ga4Id: string = (import.meta.env.PUBLIC_GA4_ID as string | undefined) || 'G-GY773BC009';

// Canonical is ALWAYS the no-trailing-slash form (root "/" excepted). This makes
// prerendered pages (built as /foo/index.html → Astro.url.pathname "/foo/") and
// any edge-served trailing-slash variant emit the no-slash canonical, matching
// the middleware 301 + the no-slash sitemap/site standard.
// Force a single leading slash so a "//evil.com/" pathname can't produce a
// cross-origin canonical/og:url (WARDEN hard-fail 2026-06-09, same root cause
// as the middleware open-redirect).
const canonicalPath = "/" + Astro.url.pathname.replace(/^[/\\]+/, "");
const canonicalURL = new URL(canonicalPath, Astro.site ?? SITE_URL);

let isPagesDevHost = false;
try {
    const requestHost = Astro.request.headers.get("host") ?? "";
    isPagesDevHost = requestHost.endsWith(".pages.dev");
} catch {
    isPagesDevHost = false;
}
const robotsContent = isPagesDevHost ? "noindex, nofollow" : robots;

// Sitewide default OG image. No dedicated 1200x630 brand OG asset exists yet
// (DESIGN follow-up); use an existing on-domain hospitality image as the default.
// Per-page hero (image prop) overrides this when supplied.
const DEFAULT_OG = `${SITE_URL}/images/og-alpha-default.png`;
const ogImage = new URL(image ?? DEFAULT_OG, SITE_URL).toString();
const ogType = article ? "article" : "website";

// Site-wide Organization schema — injected on every SwissLayout page.
// founder + knowsAbout added 2026-05-14 for EEAT/Gemini citation signal (CANVAS Sprint 6 P1-3).
const organizationLD = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${SITE_URL}/#organization`,
    name: SITE_TITLE,
    url: SITE_URL,
    address: {
        "@type": "PostalAddress",
        addressLocality: "Denpasar",
        addressRegion: "Bali",
        addressCountry: "ID",
    },
    areaServed: { "@type": "Place", name: "Bali, Indonesia" },
    contactPoint: {
        "@type": "ContactPoint",
        telephone: "+628814802249",
        email: "daniel@alphadigitalagency.id",
        contactType: "sales",
        areaServed: "ID",
        availableLanguage: ["id", "en"],
    },
    founder: {
        "@type": "Person",
        name: "Daniel Santoso",
        url: `${SITE_URL}/daniel-santoso/`,
    },
    knowsAbout: [
        "Digital Marketing Agency Bali",
        "Digital Marketing Bali",
        "Google Ads for Hotels",
        "GA4 Analytics for Hospitality",
        "Direct Booking Strategy",
        "OTA Reduction Strategy",
        "Booking Engine Integration",
        "Bali Villa Digital Marketing",
        "Hotel Revenue Management",
        "Google Tag Manager",
        "Search Console Optimization",
    ],
};

const websiteLD = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    url: SITE_URL,
    name: SITE_TITLE,
    publisher: { "@id": `${SITE_URL}/#organization` },
};

const professionalServiceLD = {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "@id": `${SITE_URL}/#professionalservice`,
    name: SITE_TITLE,
    url: SITE_URL,
    parentOrganization: { "@id": `${SITE_URL}/#organization` },
    areaServed: { "@type": "Place", name: "Bali, Indonesia" },
    serviceType: [
        "Google Ads Management",
        "Hospitality SEO",
        "Booking Engine Integration",
        "AI Agent Implementation",
        "GA4 and Search Console Tracking",
    ],
};
---

<!doctype html>
<html class="light" lang="id">
    <head>
        <meta charset="utf-8" />
        <meta
            content="width=device-width, initial-scale=1"
            name="viewport"
        />
        <meta name="build-marker" content={BUILD_MARKER} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="robots" content={robotsContent} />
        <link rel="canonical" href={canonicalURL.href} />
        <link rel="sitemap" href="/sitemap.xml" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:site_name" content={SITE_TITLE} />
        <meta property="og:type" content={ogType} />
        <meta property="og:image" content={ogImage} />
        {article?.publishedTime && (
            <meta property="article:published_time" content={article.publishedTime} />
        )}
        {article?.modifiedTime && (
            <meta property="article:modified_time" content={article.modifiedTime} />
        )}
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />
        <!-- Self-hosted Manrope — eliminates Google Fonts round-trip latency -->
        <link
            rel="preload"
            href="/fonts/manrope-latin.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <style is:inline>
            /* font-display:optional — eliminates font-swap reflow that causes LCP regression.
               Font renders immediately from cache (preload ensures it's cached); if not
               cached, system fallback is used with no layout shift. Matches BaseLayout.astro. */
            @font-face {
                font-family: 'Manrope';
                font-style: normal;
                font-weight: 300 800;
                font-display: optional;
                src: url('/fonts/manrope-latin.woff2') format('woff2');
                unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC,
                    U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329,
                    U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212,
                    U+2215, U+FEFF, U+FFFD;
            }
            /* Earliest possible background color — prevents white flash on load */
            html.light body { background-color: #f8fafc; }
            html.dark body { background-color: #020617; color: #fff; }
        </style>
        <!-- Material Symbols: non-blocking async load (icon font, not LCP-critical) -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
            media="print"
            onload="this.media='all'"
        />
        <noscript>
            <link
                href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
                rel="stylesheet"
            />
        </noscript>
        <style is:inline>
            /* SwissLayout local styles. Tailwind base/utilities come from global.css. */
            .bg-dot-grid {
                background-size: 50px 50px;
                background-image: radial-gradient(
                    circle,
                    #cbd5e1 1px,
                    transparent 1px
                );
            }
            .dark .bg-dot-grid {
                background-image: radial-gradient(
                    circle,
                    #1e293b 1px,
                    transparent 1px
                );
            }
            .btn-swiss {
                transition:
                    transform 0.15s cubic-bezier(0.4, 0, 0.2, 1),
                    box-shadow 0.15s cubic-bezier(0.4, 0, 0.2, 1);
            }
            .btn-swiss:hover {
                transform: translate(2px, 1px);
                box-shadow: 2px 1px 0px 0px rgba(15, 23, 42, 1) !important;
            }
            .btn-swiss:active {
                transform: translate(2px, 2px);
                box-shadow: none !important;
            }
            .card-swiss {
                transition:
                    transform 0.15s cubic-bezier(0.4, 0, 0.2, 1),
                    box-shadow 0.15s cubic-bezier(0.4, 0, 0.2, 1);
            }
            .card-swiss:hover {
                transform: translate(2px, 1px);
                box-shadow: 2px 1px 0px 0px rgba(15, 23, 42, 1) !important;
            }
            .gallery-item {
                position: relative;
                aspect-ratio: 1;
                overflow: hidden;
            }
            .gallery-item::after {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(
                    to top,
                    rgba(0, 0, 0, 0.5),
                    transparent
                );
                opacity: 0;
                transition: opacity 0.3s;
            }
            .gallery-item:hover::after {
                opacity: 1;
            }
            .gallery-item:hover .gallery-overlay {
                opacity: 1;
            }
            .gallery-overlay {
                opacity: 0;
                transition: opacity 0.3s;
            }
        </style>
        <!-- Site-wide entity schema -->
        <script type="application/ld+json" set:html={JSON.stringify(organizationLD)} />
        <script type="application/ld+json" set:html={JSON.stringify(websiteLD)} />
        <script type="application/ld+json" set:html={JSON.stringify(professionalServiceLD)} />
        <slot name="head" />
        {ga4Id && (
            <>
                <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
                <script is:inline define:vars={{ ga4Id }}>
                    window.dataLayer = window.dataLayer || [];
                    function gtag(){dataLayer.push(arguments);}
                    gtag('js', new Date());
                    gtag('config', ga4Id);
                </script>
            </>
        )}
    </head>
    <body
        class="bg-background-light dark:bg-background-dark text-charcoal dark:text-white min-h-screen flex flex-col font-body selection:bg-primary selection:text-white transition-colors duration-500"
    >
        <!-- Dot grid background -->
        <div
            class="fixed inset-0 z-0 pointer-events-none bg-dot-grid opacity-70"
        >
        </div>

        <SwissHeader currentPage={currentPage} />

        <main class="relative flex-1 z-10 pt-24 md:pt-32 pb-20 md:pb-0">
            <slot />
        </main>

        <SwissFooter />

        <!-- Mobile sticky CTA bar — thumb zone, bottom of screen, hidden on md+ -->
        <!-- pb-20 on main ensures content is not obscured by this bar -->
        <!-- backdrop-blur-sm removed: creates compositor layer on mobile, blocks FCP/LCP -->
        <!-- Using solid bg instead — same visual effect, zero compositor cost -->
        <!-- Icons: inline SVG instead of Material Symbols — eliminates async font LCP blocker.
             Material Symbols loads via media="print" onload (async), making icon spans
             LCP candidates that don't resolve until font arrives (~7s on throttled mobile).
             Inline SVGs render at parse time, zero font dependency, same visual. -->
        <div
            class="fixed bottom-0 left-0 right-0 z-50 md:hidden border-t border-slate-200 dark:border-slate-700 bg-background-light dark:bg-background-dark flex"
        >
            <a
                href="tel:08814802249"
                class="flex-1 flex flex-col items-center justify-center gap-0.5 py-2.5 text-charcoal dark:text-white hover:text-primary transition-colors min-h-[52px]"
                aria-label="Call us"
            >
                <!-- Phone SVG -->
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                <span class="text-[9px] font-bold uppercase tracking-wider">Call</span>
            </a>
            <div class="w-px bg-slate-200 dark:bg-slate-700 my-2"></div>
            <a
                href="https://wa.me/628814802249"
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 flex flex-col items-center justify-center gap-0.5 py-2.5 bg-primary text-white hover:bg-primary-dark transition-colors min-h-[52px]"
                aria-label="WhatsApp us"
            >
                <!-- Chat/WhatsApp SVG -->
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg>
                <span class="text-[9px] font-bold uppercase tracking-wider">WhatsApp</span>
            </a>
            <div class="w-px bg-slate-200 dark:bg-slate-700 my-2"></div>
            <a
                id="mobile-cta-email"
                href="#"
                data-e="daniel"
                data-d="alphadigitalagency.id"
                class="flex-1 flex flex-col items-center justify-center gap-0.5 py-2.5 text-charcoal dark:text-white hover:text-primary transition-colors min-h-[52px]"
                aria-label="Email us"
            >
                <!-- Mail SVG -->
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                <span class="text-[9px] font-bold uppercase tracking-wider">Email</span>
            </a>
        </div>
        <script is:inline>
            var me = document.getElementById('mobile-cta-email');
            if (me) me.href = 'mailto:' + me.dataset.e + '@' + me.dataset.d;
        </script>
        <script src="https://starter.alphadigitalagency.id/widget.js" data-tenant="alpha" data-mode="floating" data-width="420" data-height="720"></script>
    </body>
</html>
