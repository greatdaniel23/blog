---
import SwissHeader from "./SwissHeader.astro";
import SwissFooter from "./SwissFooter.astro";
import "../styles/global.css";

interface Props {
    title: string;
    currentPage?: string;
}

const { title, currentPage = "" } = Astro.props;
---

<!doctype html>
<html class="light" lang="en">
    <head>
        <meta charset="utf-8" />
        <meta
            content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
            name="viewport"
        />
        <title>{title}</title>
        <!-- preconnect → eliminates DNS + TLS round-trip from render path -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <!-- media="print" + onload swap = non-render-blocking font load -->
        <link
            href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap"
            rel="stylesheet"
            media="print"
            onload="this.media='all'"
        />
        <noscript>
            <link
                href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap"
                rel="stylesheet"
            />
        </noscript>
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
            media="print"
            onload="this.media='all'"
        />
        <noscript>
            <link
                href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
                rel="stylesheet"
            />
        </noscript>
        <style is:inline>
            /* SwissLayout local styles. Tailwind base/utilities come from global.css. */
            .bg-dot-grid {
                background-size: 50px 50px;
                background-image: radial-gradient(
                    circle,
                    #cbd5e1 1px,
                    transparent 1px
                );
            }
            .dark .bg-dot-grid {
                background-image: radial-gradient(
                    circle,
                    #1e293b 1px,
                    transparent 1px
                );
            }
            .btn-swiss {
                transition:
                    transform 0.15s cubic-bezier(0.4, 0, 0.2, 1),
                    box-shadow 0.15s cubic-bezier(0.4, 0, 0.2, 1);
            }
            .btn-swiss:hover {
                transform: translate(2px, 1px);
                box-shadow: 2px 1px 0px 0px rgba(15, 23, 42, 1) !important;
            }
            .btn-swiss:active {
                transform: translate(2px, 2px);
                box-shadow: none !important;
            }
            .card-swiss {
                transition:
                    transform 0.15s cubic-bezier(0.4, 0, 0.2, 1),
                    box-shadow 0.15s cubic-bezier(0.4, 0, 0.2, 1);
            }
            .card-swiss:hover {
                transform: translate(2px, 1px);
                box-shadow: 2px 1px 0px 0px rgba(15, 23, 42, 1) !important;
            }
            .gallery-item {
                position: relative;
                aspect-ratio: 1;
                overflow: hidden;
            }
            .gallery-item::after {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(
                    to top,
                    rgba(0, 0, 0, 0.5),
                    transparent
                );
                opacity: 0;
                transition: opacity 0.3s;
            }
            .gallery-item:hover::after {
                opacity: 1;
            }
            .gallery-item:hover .gallery-overlay {
                opacity: 1;
            }
            .gallery-overlay {
                opacity: 0;
                transition: opacity 0.3s;
            }
        </style>
        <slot name="head" />
    </head>
    <body
        class="bg-background-light dark:bg-background-dark text-charcoal dark:text-white min-h-screen flex flex-col font-body selection:bg-primary selection:text-white transition-colors duration-500"
    >
        <!-- Dot grid background -->
        <div
            class="fixed inset-0 z-0 pointer-events-none bg-dot-grid opacity-70"
        >
        </div>

        <SwissHeader currentPage={currentPage} />

        <main class="relative flex-1 z-10 pt-24 md:pt-32">
            <slot />
        </main>

        <SwissFooter />
    </body>
</html>
