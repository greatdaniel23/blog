---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import { AstroSeo as SEO } from "@astrolib/seo";
import "../styles/global.css";
import type { ImageMetadata } from "astro";
import FallbackImage from "../assets/blog-placeholder-1.jpg";
import {
	SITE_TITLE,
	SITE_DESCRIPTION,
	SITE_URL,
	SITE_LOGO,
	SITE_SOCIAL,
} from "../consts";

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	article?: {
		publishedTime?: string;
		modifiedTime?: string;
		author?: string;
		section?: string;
		tags?: string[];
	};
	breadcrumbs?: { name: string; url: string }[];
	jsonLd?: object | object[];
}

// Canonical is ALWAYS the no-trailing-slash form (root "/" excepted) — matches
// the middleware 301, the no-slash sitemap, and prevents prerendered pages
// (built as /foo/index.html → pathname "/foo/") emitting a trailing-slash canonical.
// Force a single leading slash so a "//evil.com/" pathname can't produce a
// cross-origin canonical (WARDEN hard-fail 2026-06-09).
const canonicalPath = "/" + Astro.url.pathname.replace(/^[/\\]+/, "");
const canonicalURL = new URL(canonicalPath, Astro.site ?? SITE_URL);
const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";

// Prevent pages.dev preview subdomain from being indexed.
// Only available in SSR context; prerendered pages rely on the middleware
// X-Robots-Tag header instead (set in src/middleware.ts).
let isPagesDevHost = false;
try {
  const requestHost = Astro.request.headers.get('host') ?? '';
  isPagesDevHost = requestHost.endsWith('.pages.dev');
} catch {
  // headers not available in prerender context — middleware handles it
}

// GA4 Measurement ID — public by design, safe to hardcode in static HTML.
// import.meta.env.PUBLIC_GA4_ID feeds this at build time when the env var is set
// (CF Pages build environment or local .env); hardcoded fallback ensures the snippet
// is never absent from prerendered HTML even when the env var is not explicitly set.
// Replaces the previous runtime D1 gtm_settings read which could never fire on
// prerender=true pages (no Cloudflare bindings at build time). The gtm_settings
// table and /pembantu settings UI are left intact.
const ga4Id: string = (import.meta.env.PUBLIC_GA4_ID as string | undefined) || 'G-GY773BC009';

const {
	title,
	description,
	image = FallbackImage,
	article,
	breadcrumbs,
	jsonLd,
} = Astro.props;

const ogImageURL = new URL(image.src, Astro.url).toString();

// --- Site-wide structured data ---
// Build sameAs only from confirmed social URLs. Omit the field entirely
// when none confirmed — empty/guessed URLs in Organization sameAs can
// cause Knowledge Graph entity contamination (e.g. linking Alpha agency
// to a personal account). Pending Daniel Decision Inbox D-002 / D-003.
const sameAsList = [SITE_SOCIAL.linkedin, SITE_SOCIAL.threads].filter(
	(u): u is string => typeof u === "string" && u.length > 0,
);

const organizationLD: Record<string, unknown> = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"@id": `${SITE_URL}/#organization`,
	name: SITE_TITLE,
	url: SITE_URL,
	logo: {
		"@type": "ImageObject",
		url: SITE_LOGO,
	},
	address: {
		"@type": "PostalAddress",
		addressLocality: "Denpasar",
		addressRegion: "Bali",
		addressCountry: "ID",
	},
	contactPoint: {
		"@type": "ContactPoint",
		telephone: "+628814802249",
		email: "daniel@alphadigitalagency.id",
		contactType: "sales",
		areaServed: "ID",
		availableLanguage: ["id", "en"],
	},
	areaServed: { "@type": "Place", name: "Bali, Indonesia" },
	founder: {
		"@type": "Person",
		name: "Daniel Santoso",
		url: `${SITE_URL}/daniel-santoso/`,
	},
	knowsAbout: [
		"Digital Marketing Agency Bali",
		"Digital Marketing Bali",
		"Google Ads for Hotels",
		"GA4 Analytics for Hospitality",
		"Direct Booking Strategy",
		"OTA Reduction Strategy",
		"Booking Engine Integration",
		"Bali Villa Digital Marketing",
		"Hotel Revenue Management",
		"Google Tag Manager",
		"Search Console Optimization",
	],
};
if (sameAsList.length > 0) {
	organizationLD.sameAs = sameAsList;
}

const websiteLD = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"@id": `${SITE_URL}/#website`,
	url: SITE_URL,
	name: SITE_TITLE,
	description: SITE_DESCRIPTION,
	publisher: { "@id": `${SITE_URL}/#organization` },
	potentialAction: {
		"@type": "SearchAction",
		target: {
			"@type": "EntryPoint",
			urlTemplate: `${SITE_URL}/?q={search_term_string}`,
		},
		"query-input": "required name=search_term_string",
	},
};

const breadcrumbLD = breadcrumbs && breadcrumbs.length
	? {
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			itemListElement: breadcrumbs.map((b, i) => ({
				"@type": "ListItem",
				position: i + 1,
				name: b.name,
				item: new URL(b.url, SITE_URL).toString(),
			})),
		}
	: null;

const articleLD = article
	? {
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			headline: title,
			description,
			image: ogImageURL,
			datePublished: article.publishedTime,
			dateModified: article.modifiedTime ?? article.publishedTime,
			author: {
				"@type": "Person",
				name: article.author ?? "Daniel",
			},
			publisher: { "@id": `${SITE_URL}/#organization` },
			mainEntityOfPage: canonicalURL.href,
			articleSection: article.section,
			keywords: article.tags,
		}
	: null;

const extraLD = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const allLD = [
	organizationLD,
	websiteLD,
	breadcrumbLD,
	articleLD,
	...extraLD,
].filter(Boolean);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="robots" content={isPagesDevHost ? "noindex, nofollow" : "index, follow"} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL("rss.xml", Astro.site ?? SITE_URL)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Atkinson font preloads REMOVED — site uses Manrope only (tailwind.config.mjs
     fontFamily: display+body both set to Manrope). Preloading unused fonts wastes
     bandwidth and preload scanner slots, contributing to render-blocking delay.
     Manrope is preloaded in BaseLayout.astro where @font-face is declared. -->

<!-- SEO Component -->
<SEO
	title={title}
	description={description}
	openGraph={{
		title: title,
		description: description,
		type: article ? "article" : "website",
		url: canonicalURL.href,
		site_name: SITE_TITLE,
		images: [
			{
				url: ogImageURL,
				alt: title,
			},
		],
	}}
	twitter={{
		card: "summary_large_image",
		title: title,
		image: ogImageURL,
		description: description,
		imageAlt: title,
	}}
	extend={{
		link: [{ rel: "canonical", href: canonicalURL.href }],
		meta: [],
	}}
/>

{allLD.map((ld) => (
	<script type="application/ld+json" set:html={JSON.stringify(ld)} />
))}

{ga4Id && (
    <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ ga4Id }}>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', ga4Id);
        </script>
    </>
)}
