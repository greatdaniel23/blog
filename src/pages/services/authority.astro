---
export const prerender = true;
import SwissLayout from "../../components/SwissLayout.astro";

const serviceLD = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Authority — Full-Funnel Marketing untuk Multi-Properti Bali",
  "provider": {
    "@type": "Organization",
    "name": "Alpha Digital Agency",
    "url": "https://alphadigitalagency.id"
  },
  "author": {
    "@type": "Person",
    "name": "Daniel Santoso",
    "url": "https://alphadigitalagency.id/daniel-santoso/#person"
  },
  "areaServed": "Bali, Indonesia",
  "description": "Google Ads → AI Chatbot → Booking Engine → GA4 — satu pipeline terintegrasi yang menggeser 15-30% pemesanan OTA ke direct booking. Untuk luxury hospitality group di Bali.",
  "serviceType": "Full-Funnel Digital Marketing",
  "url": "https://alphadigitalagency.id/services/authority/"
};

const faqItems = [
  {
    q: "Apa yang dimaksud dengan pipeline Google Ads → Chatbot → Booking Engine → GA4?",
    a: "Ini adalah empat layer yang bekerja sebagai satu sistem. Google Ads membawa tamu yang tepat ke website properti Anda. AI Chatbot merekomendasikan kamar berdasarkan Place ID dan database properti Anda — tersedia 24 jam. Booking Engine memproses reservasi langsung tanpa komisi OTA. GA4 mengukur seluruh perjalanan tamu dari klik iklan hingga konfirmasi booking — sehingga setiap keputusan budget berdasarkan data nyata."
  },
  {
    q: "Bagaimana cara kerja pergeseran OTA ke direct booking?",
    a: "OTA mengambil 15-25% komisi per kamar terjual. Tamu yang memesan via OTA sering datang dari branded query — artinya mereka sebenarnya sudah mencari properti Anda, tapi diarahkan ke platform perantara terlebih dahulu. Kami identifikasi kebocoran ini, bangun funnel direct booking yang lebih mulus, dan ukur pergeserannya via GA4. Target: 15-30% shift dari OTA ke direct dalam 90 hari."
  },
  {
    q: "Mengapa TripAdvisor penting untuk Authority tier?",
    a: "TripAdvisor adalah lever tunggal yang paling efisien: satu investasi menghasilkan tiga efek — Maps Prominence naik, SERP backlink signal naik, dan visibilitas di Gemini AI naik. Properti yang masuk top 10 TripAdvisor di micro-area mereka cenderung muncul otomatis di rekomendasi AI untuk area tersebut. Kami monitor dan optimalkan posisi TripAdvisor Anda sebagai bagian dari Authority tier."
  },
  {
    q: "Apa yang dimaksud dengan 'brand-SERP defense'?",
    a: "Ketika tamu mengetik nama properti Anda di Google, halaman pertama idealnya dikuasai oleh website Anda sendiri — bukan OTA atau kompetitor. Kami deteksi branded query yang diarahkan ke OTA, bangun branded campaign Google Ads, dan optimalkan GBP + website untuk merebut kembali slot tersebut."
  },
  {
    q: "Apakah Authority cocok untuk properti tunggal?",
    a: "Authority dirancang untuk properti yang sudah memiliki Google Ads berjalan dan ingin naik ke level berikutnya: semua channel terhubung, AI Chatbot + Booking Engine terintegrasi, dan data GA4 mengukur seluruh funnel. Untuk single property yang baru mulai, Growth biasanya lebih efisien dulu."
  },
  {
    q: "Bagaimana cara kerja koordinasi multi-properti?",
    a: "Kami kelola campaign Ads, AI Chatbot, dan data tracking untuk masing-masing properti secara independen — tapi laporan konsolidasi memperlihatkan performa semua properti dalam satu tampilan. Keputusan budget bisa dibuat di level grup dengan data yang akurat per properti."
  }
];

const faqLD = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};

const breadcrumbLD = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://alphadigitalagency.id/" },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://alphadigitalagency.id/services/" },
    { "@type": "ListItem", "position": 3, "name": "Authority", "item": "https://alphadigitalagency.id/services/authority/" }
  ]
};
---

<SwissLayout
  title="Full-Funnel Hotel Marketing Bali | Alpha Digital"
  description="Full-funnel marketing for Bali hospitality groups: Google Ads, direct booking, AI agent, SEO, and reporting coordinated across multi-property portfolios."
  currentPage="services"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceLD)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLD)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD)} />
  </Fragment>

  <!-- Hero -->
  <section class="max-w-4xl mx-auto mb-12 px-6 md:px-12 text-center">
    <p class="text-xs font-mono uppercase tracking-widest text-primary mb-4">Tier 3 — Authority</p>
    <h1
      class="font-display font-extrabold text-charcoal dark:text-white leading-display tracking-tightest text-[2rem] sm:text-[3rem] md:text-[4rem] lg:text-[5rem] mb-6"
    >
      Geser 15–30% Booking dari OTA ke Direct<span class="text-primary">.</span>
    </h1>
    <p class="text-slate-600 dark:text-slate-400 text-base md:text-lg max-w-2xl mx-auto leading-relaxed">
      Satu pipeline terintegrasi: Google Ads membawa tamu yang tepat, AI Chatbot merekomendasikan kamar 24 jam, Booking Engine memproses reservasi langsung, GA4 mengukur seluruh funnel. Untuk luxury hospitality group di Bali yang ingin berhenti membayar komisi OTA tanpa batas.
    </p>
    <div class="mt-8">
      <a
        href="mailto:daniel@alphadigitalagency.id"
        class="btn-swiss inline-flex items-center gap-2 px-8 py-4 bg-primary text-white border-2 border-charcoal shadow-premium font-bold text-sm uppercase tracking-widest"
      >
        <span class="material-symbols-outlined">mail</span>
        Minta Penawaran
      </a>
    </div>
  </section>

  <!-- Pipeline chain — LDF + Thesis spine -->
  <section class="max-w-4xl mx-auto mb-8 px-6 md:px-12">
    <div class="bg-primary/5 dark:bg-primary/10 border-l-4 border-primary p-6 md:p-8">
      <p class="text-xs font-mono uppercase tracking-widest text-primary mb-3">The Pipeline</p>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-3 flex-wrap">
        <span class="font-bold text-charcoal dark:text-white text-sm">Google Ads</span>
        <span class="text-primary font-bold text-lg hidden sm:block">→</span>
        <span class="text-primary font-bold text-lg sm:hidden">↓</span>
        <span class="font-bold text-charcoal dark:text-white text-sm">AI Chatbot</span>
        <span class="text-primary font-bold text-lg hidden sm:block">→</span>
        <span class="text-primary font-bold text-lg sm:hidden">↓</span>
        <span class="font-bold text-charcoal dark:text-white text-sm">Booking Engine</span>
        <span class="text-primary font-bold text-lg hidden sm:block">→</span>
        <span class="text-primary font-bold text-lg sm:hidden">↓</span>
        <span class="font-bold text-charcoal dark:text-white text-sm">GA4</span>
        <span class="text-primary font-bold text-lg hidden sm:block">→</span>
        <span class="text-primary font-bold text-lg sm:hidden">↓</span>
        <span class="font-bold text-primary text-sm">15–30% OTA → Direct Shift</span>
      </div>
      <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mt-4">
        OTA mengambil 15–25% komisi per kamar. Kami bangun jalur alternatif yang lebih menguntungkan properti Anda — dan ukur pergeserannya dengan data, bukan estimasi.
      </p>
    </div>
  </section>

  <!-- The four layers explained -->
  <section class="max-w-4xl mx-auto mb-8 px-6 md:px-12">
    <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12">
      <h2 class="font-display font-bold text-2xl md:text-3xl text-charcoal dark:text-white mb-8">
        Empat Layer, Satu Sistem
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex gap-4 items-start">
          <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm flex-shrink-0">1</div>
          <div>
            <h3 class="font-bold text-charcoal dark:text-white mb-1">Google Ads — 9 Tahun Kedalaman</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Kampanye yang menjangkau tamu dengan intent booking — bukan sekadar traffic. Brand-SERP defense mencegah OTA mengambil slot branded query properti Anda. Budget dialokasikan berdasarkan data channel × negara yang telah terbukti convert.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm flex-shrink-0">2</div>
          <div>
            <h3 class="font-bold text-charcoal dark:text-white mb-1">AI Chatbot — Rekomendasi Kamar 24 Jam</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Asisten digital yang dipasang di website properti Anda. Merekomendasikan kamar berdasarkan Google Place ID dan database properti — menjawab pertanyaan tamu kapan saja, mendorong ke booking engine langsung tanpa perantara OTA.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm flex-shrink-0">3</div>
          <div>
            <h3 class="font-bold text-charcoal dark:text-white mb-1">Booking Engine — Direct, Tanpa Komisi OTA</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Tamu memesan langsung dari website Anda. Tidak ada komisi platform perantara, tidak ada lock-in vendor. Data booking mengalir langsung ke laporan GA4 Anda — sehingga setiap konversi bisa diatribusikan ke channel yang tepat.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm flex-shrink-0">4</div>
          <div>
            <h3 class="font-bold text-charcoal dark:text-white mb-1">GA4 + MCP — Satu Ekosistem Data</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Google Ads, Search Console, Maps, dan booking engine terhubung dalam satu laporan. Setiap reservasi ditelusuri dari keyword mana, channel mana, kampanye mana. Untuk properti multi-lokasi: Anda tahu properti mana yang underperform dan mengapa.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TripAdvisor Cascade / LDF layer -->
  <section class="max-w-4xl mx-auto mb-8 px-6 md:px-12">
    <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12">
      <h2 class="font-display font-bold text-xl md:text-2xl text-charcoal dark:text-white mb-4">
        Visibilitas AI: Dari TripAdvisor ke Gemini
      </h2>
      <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
        AI recommendation engine — Gemini, ChatGPT, Google AI Overview — tidak meranking properti dari nol. Mereka mengagregasi pemimpin dari beberapa layer discovery di bawahnya: SERP, Google Maps, TripAdvisor, dan Editorial.
      </p>
      <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
        TripAdvisor adalah lever yang paling efisien: satu investasi menghasilkan tiga efek downstream — Maps Prominence naik, SERP backlink signal naik, dan visibilitas langsung di hasil AI naik. Properti yang masuk top 10 TripAdvisor di micro-area mereka (bukan kota-wide) cenderung muncul otomatis dalam rekomendasi AI untuk area tersebut.
      </p>
      <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
        Authority tier mencakup audit posisi properti Anda di keempat layer ini — dan rekomendasi layer mana yang paling efisien untuk dimenangkan berdasarkan profil properti Anda saat ini.
      </p>
    </div>
  </section>

  <!-- Proof anchor -->
  <section class="max-w-4xl mx-auto mb-8 px-6 md:px-12">
    <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12">
      <h2 class="font-display font-bold text-xl md:text-2xl text-charcoal dark:text-white mb-4">
        Hasil yang Bisa Diukur
      </h2>
      <blockquote class="border-l-4 border-primary pl-6 py-2 mb-4">
        <p class="text-slate-700 dark:text-slate-300 text-base leading-relaxed italic mb-2">
          "Properti vila Bali dengan 4 unit — direct booking naik 34% dalam 90 hari setelah audit funnel + optimasi Google Ads. Full breakdown: <a href="mailto:daniel@alphadigitalagency.id" class="text-primary not-italic underline">Minta laporan methodology</a>"
        </p>
        <cite class="text-xs font-mono uppercase tracking-widest text-slate-500 dark:text-slate-400 not-italic">
          — Verified client data. Name withheld per client policy.
        </cite>
      </blockquote>
      <p class="text-slate-500 dark:text-slate-400 text-xs">
        Case Study #1 — diukur via GA4 direct booking conversion tracking, window 90 hari, Month 1 baseline vs Month 3 result. Full breakdown tersedia untuk prospek yang qualified.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-4xl mx-auto mb-8 px-6 md:px-12">
    <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12">
      <h2 class="font-display font-bold text-2xl md:text-3xl text-charcoal dark:text-white mb-8">
        Pertanyaan tentang Authority
      </h2>
      <div class="space-y-6">
        {faqItems.map((item) => (
          <div class="border-b border-slate-200 dark:border-slate-700 pb-6 last:border-0 last:pb-0">
            <h3 class="font-bold text-charcoal dark:text-white mb-2">{item.q}</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Internal links -->
  <section class="max-w-4xl mx-auto mb-12 px-6 md:px-12">
    <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-4 text-center">
      Authority adalah paket full-funnel dari <a href="/" class="text-primary font-semibold hover:underline">digital marketing agency Bali</a> yang fokus pada hospitality: channel, tracking, booking engine, dan reporting disatukan.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href="/services/foundation" class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-5 card-swiss block text-center">
        <p class="text-xs font-mono uppercase tracking-widest text-primary mb-2">Tier 1</p>
        <p class="font-bold text-charcoal dark:text-white">Foundation →</p>
        <p class="text-slate-600 dark:text-slate-400 text-xs mt-1">Tracking &amp; analytics setup</p>
      </a>
      <a href="/services/growth" class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-5 card-swiss block text-center">
        <p class="text-xs font-mono uppercase tracking-widest text-primary mb-2">Tier 2</p>
        <p class="font-bold text-charcoal dark:text-white">Growth →</p>
        <p class="text-slate-600 dark:text-slate-400 text-xs mt-1">Google Ads untuk satu properti</p>
      </a>
      <a href="/services/booking-integration" class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-5 card-swiss block text-center">
        <p class="text-xs font-mono uppercase tracking-widest text-primary mb-2">Tier 4</p>
        <p class="font-bold text-charcoal dark:text-white">Booking Engine →</p>
        <p class="text-slate-600 dark:text-slate-400 text-xs mt-1">Install tanpa lock-in vendor</p>
      </a>
    </div>
  </section>

  <!-- Author byline -->
  <section class="max-w-4xl mx-auto mb-4 px-6 md:px-12">
    <p class="text-xs text-slate-500 dark:text-slate-400">
      Ditulis oleh <a href="/daniel-santoso/" class="underline hover:text-primary">Daniel Santoso</a> · Terakhir diperbarui: Mei 2026
    </p>
  </section>

  <!-- Final CTA -->
  <section class="max-w-4xl mx-auto mb-16 px-6 md:px-12 text-center">
    <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12">
      <h2 class="font-display font-bold text-2xl md:text-3xl text-charcoal dark:text-white mb-4">
        Siap ke Level Authority?
      </h2>
      <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-8 max-w-lg mx-auto">
        Ceritakan situasi properti Anda sekarang. Kami audit dan jelaskan gap yang paling berdampak pertama.
      </p>
      <a
        href="mailto:daniel@alphadigitalagency.id"
        class="btn-swiss inline-flex items-center gap-2 px-8 py-4 bg-primary text-white border-2 border-charcoal shadow-premium font-bold text-sm uppercase tracking-widest"
      >
        <span class="material-symbols-outlined">mail</span>
        Minta Penawaran
      </a>
    </div>
  </section>
</SwissLayout>
