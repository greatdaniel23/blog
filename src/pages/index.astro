---
// Static page — prerender at build time for best LCP/TTFB performance.
// No dynamic runtime data needed on homepage.
export const prerender = true;

import SwissLayout from "../components/SwissLayout.astro";

const homeFaqItems = [
  {
    q: "Apa yang membedakan Alpha Digital dari agency lain di Bali?",
    a: "Alpha Digital menggabungkan Google Ads, SEO organik, dan booking engine langsung dalam satu sistem laporan. Bukan tiga vendor terpisah — satu tim, satu data, satu tujuan: reservasi langsung lebih banyak."
  },
  {
    q: "Apa itu digital marketing agency Bali untuk hospitality?",
    a: "Digital marketing agency Bali untuk hospitality adalah partner yang memahami pasar hotel, vila, restoran, OTA, direct booking, dan tracking reservasi. Alpha Digital fokus di titik itu: Google Ads, SEO, booking engine, GA4, dan AI Agent yang saling terhubung."
  },
  {
    q: "Apa bedanya Alpha Digital dengan creative agency atau social media agency?",
    a: "Creative agency biasanya fokus pada brand dan konten visual. Social media agency fokus pada kalender konten dan engagement. Alpha Digital fokus pada sistem pendapatan digital: iklan, SEO, tracking, booking engine, dan laporan reservasi langsung."
  },
  {
    q: "Apakah Alpha Digital hanya melayani vila dan hotel di Bali?",
    a: "Spesialisasi kami adalah hospitality Bali — vila, hotel boutique, dan restoran. Kami tidak melayani semua industri karena fokus adalah kunci hasil terbaik."
  },
  {
    q: "Layanan apa yang sebaiknya dimiliki digital marketing agency Bali untuk hotel?",
    a: "Minimal harus bisa mengelola Google Ads, membaca Search Console, memasang GA4/GTM, memperbaiki website, memahami booking engine, dan mengukur direct booking. Tanpa itu, laporan marketing mudah berhenti di klik dan engagement."
  },
  {
    q: "Berapa lama sebelum saya melihat hasil dari Google Ads?",
    a: "Kampanye Google Ads biasanya mulai menghasilkan data bermakna dalam 2–4 minggu pertama. Optimasi dilakukan dua minggu sekali berdasarkan data nyata, bukan asumsi."
  },
  {
    q: "Apakah saya perlu sudah punya website untuk mulai?",
    a: "Tidak harus. Kami bisa audit website yang sudah ada, atau bantu dari awal. Yang paling penting adalah tracking yang benar sebelum budget iklan dibakar."
  },
  {
    q: "Bagaimana cara memulai dengan Alpha Digital?",
    a: "Kirim email ke daniel@alphadigitalagency.id atau WhatsApp ke 0881 480 2249. Kami mulai dengan audit cepat situasi digital properti Anda — gratis, tanpa komitmen."
  }
];

const localBusinessLD = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  "@id": "https://alphadigitalagency.id/#localbusiness",
  "parentOrganization": { "@id": "https://alphadigitalagency.id/#organization" },
  "name": "Alpha Digital Agency",
  "url": "https://alphadigitalagency.id",
  "description": "Digital marketing agency Bali untuk vila dan hotel: Google Ads, SEO, booking engine, GA4 tracking, dan AI agent dalam satu sistem laporan.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Denpasar",
    "addressRegion": "Bali",
    "addressCountry": "ID"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -8.6705,
    "longitude": 115.2126
  },
  "areaServed": { "@type": "Place", "name": "Bali, Indonesia" },
  "priceRange": "$$",
  "telephone": "+628814802249",
  "email": "daniel@alphadigitalagency.id",
  "knowsAbout": ["Digital Marketing Agency Bali", "Digital Marketing Bali", "Google Ads", "SEO", "GA4", "Booking Engine", "Hospitality Marketing", "Bali"]
};

const homeFaqLD = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": homeFaqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};

const homeBreadcrumbLD = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://alphadigitalagency.id/" }
  ]
};
---

<SwissLayout
	title="Digital Marketing Agency Bali | Alpha Digital"
	description="Digital marketing agency Bali for hotels and villas: Google Ads, SEO, booking engine, GA4 tracking, AI agents, and direct booking growth."
	currentPage="home"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(localBusinessLD)} />
        <script type="application/ld+json" set:html={JSON.stringify(homeFaqLD)} />
        <script type="application/ld+json" set:html={JSON.stringify(homeBreadcrumbLD)} />
        {/* Agency AI Assistant widget — agent_id=5, same-origin /api/* only */}
        <script
            src="/assets/agency-agent-widget.js"
            data-agent-id="5"
            data-api-url="/api/chat"
            data-greeting="Halo! Saya asisten Alpha Digital. Ada yang bisa saya bantu soal digital marketing bisnis Anda?"
            data-accent="#10b981"
            defer
            is:inline
        ></script>
    </Fragment>
	<!-- ── Hero ── -->
	<section
		class="relative flex-1 flex flex-col items-center justify-center min-h-[calc(100svh-80px)] w-full px-4 pb-24 md:pb-12"
	>
		<div
			class="absolute inset-0 bg-radial-gradient from-emerald-500/5 to-transparent blur-[100px] pointer-events-none z-0"
		>
		</div>

		<div
			class="relative z-10 flex flex-col items-center justify-center max-w-[1400px] w-full text-center gap-3 lg:gap-4"
		>
			<!-- Headline -->
			<div class="flex-none mb-3 md:mb-4">
				<h1
					class="flex flex-col items-center font-display font-extrabold text-charcoal dark:text-white leading-display tracking-tightest"
				>
					<span
						class="text-[2rem] sm:text-[2.8rem] md:text-[3.5rem] lg:text-[4rem] xl:text-[5rem] 2xl:text-[6rem] drop-shadow-sm transition-all duration-300 text-center max-w-4xl"
					>
						Digital marketing agency Bali untuk hotel dan vila.
					</span>
				</h1>
				<p
					class="mt-3 md:mt-4 text-xs sm:text-sm md:text-base text-slate-600 dark:text-slate-400 font-medium max-w-[90%] md:max-w-2xl mx-auto leading-relaxed tracking-wide text-center"
				>
					Kami gabungkan Google Ads, SEO, booking engine, GA4 tracking, dan AI Agent dalam satu sistem, supaya setiap rupiah marketing kelihatan hasilnya. Spesialis hospitality Bali yang ingin kurangi ketergantungan OTA.
				</p>
			</div>

			<!-- Mobile (< 768px): flat chip row — zero compositor cost, instant paint -->
			<div class="flex-none w-full flex items-center justify-center gap-2 flex-wrap px-4 my-2 md:hidden">
				<span class="text-[9px] font-mono font-bold uppercase tracking-[0.15em] text-slate-600 dark:text-slate-400 px-3 py-1.5 rounded-full bg-white/70 dark:bg-slate-900/70 border border-slate-200/50 dark:border-slate-700/50 whitespace-nowrap">GTM Strategy</span>
				<span class="text-[9px] font-mono font-bold uppercase tracking-[0.15em] text-slate-600 dark:text-slate-400 px-3 py-1.5 rounded-full bg-white/70 dark:bg-slate-900/70 border border-slate-200/50 dark:border-slate-700/50 whitespace-nowrap">GA4 Analytics</span>
				<span class="text-[9px] font-mono font-bold uppercase tracking-[0.15em] text-slate-600 dark:text-slate-400 px-3 py-1.5 rounded-full bg-white/70 dark:bg-slate-900/70 border border-slate-200/50 dark:border-slate-700/50 whitespace-nowrap">Google Ads</span>
				<span class="text-[9px] font-mono font-bold uppercase tracking-[0.15em] text-slate-600 dark:text-slate-400 px-3 py-1.5 rounded-full bg-white/70 dark:bg-slate-900/70 border border-slate-200/50 dark:border-slate-700/50 whitespace-nowrap">AI Agents</span>
			</div>

			<!-- Desktop (768px+): 3D orbit animation — compositor layer OK on larger screens -->
			<div
				class="orbit-mobile-hidden flex-none w-full items-center justify-center relative perspective-container z-30 group cursor-default orbit-container-height my-0 md:my-1"
			>
				<div
					class="orbit-axis w-0 h-0 relative scale-[0.6] sm:scale-[0.7] md:scale-[0.85] lg:scale-[1.0] xl:scale-100 origin-center transition-transform duration-500"
				>
					<div
						class="orbit-item"
						style="transform: rotateY(0deg) translateZ(var(--orbit-radius));"
					>
						<div
							class="orbit-content flex items-center gap-2 px-3 py-1.5 md:px-5 md:py-2.5 rounded-full bg-white/70 dark:bg-slate-900/70 backdrop-blur-md border border-slate-200/50 dark:border-slate-700/50 transition-colors"
							style="animation-delay: 0s;"
						>
							<div class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-glow"></div>
							<span class="text-[10px] md:text-[11px] font-mono font-bold text-slate-700 dark:text-slate-200 uppercase tracking-[0.15em] whitespace-nowrap">GTM Strategy</span>
						</div>
					</div>
					<div
						class="orbit-item"
						style="transform: rotateY(60deg) translateZ(var(--orbit-radius));"
					>
						<div
							class="orbit-content flex items-center gap-2 px-3 py-1.5 md:px-5 md:py-2.5 rounded-full bg-white/70 dark:bg-slate-900/70 backdrop-blur-md border border-slate-200/50 dark:border-slate-700/50 transition-colors"
							style="animation-delay: -20s;"
						>
							<div class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-glow"></div>
							<span class="text-[10px] md:text-[11px] font-mono font-bold text-slate-700 dark:text-slate-200 uppercase tracking-[0.15em] whitespace-nowrap">GA4 Analytics</span>
						</div>
					</div>
					<div
						class="orbit-item"
						style="transform: rotateY(120deg) translateZ(var(--orbit-radius));"
					>
						<div
							class="orbit-content flex items-center gap-2 px-3 py-1.5 md:px-5 md:py-2.5 rounded-full bg-white/70 dark:bg-slate-900/70 backdrop-blur-md border border-slate-200/50 dark:border-slate-700/50 transition-colors"
							style="animation-delay: -16s;"
						>
							<div class="w-1.5 h-1.5 rounded-full bg-emerald-600 shadow-glow"></div>
							<span class="text-[10px] md:text-[11px] font-mono font-bold text-slate-700 dark:text-slate-200 uppercase tracking-[0.15em] whitespace-nowrap">BigQuery</span>
						</div>
					</div>
					<div
						class="orbit-item"
						style="transform: rotateY(180deg) translateZ(var(--orbit-radius));"
					>
						<div
							class="orbit-content flex items-center gap-2 px-3 py-1.5 md:px-5 md:py-2.5 rounded-full bg-white/70 dark:bg-slate-900/70 backdrop-blur-md border border-slate-200/50 dark:border-slate-700/50 transition-colors"
							style="animation-delay: -12s;"
						>
							<div class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-glow"></div>
							<span class="text-[10px] md:text-[11px] font-mono font-bold text-slate-700 dark:text-slate-200 uppercase tracking-[0.15em] whitespace-nowrap">Looker Studio</span>
						</div>
					</div>
					<div
						class="orbit-item"
						style="transform: rotateY(240deg) translateZ(var(--orbit-radius));"
					>
						<div
							class="orbit-content flex items-center gap-2 px-3 py-1.5 md:px-5 md:py-2.5 rounded-full bg-white/70 dark:bg-slate-900/70 backdrop-blur-md border border-slate-200/50 dark:border-slate-700/50 transition-colors"
							style="animation-delay: -8s;"
						>
							<div class="w-1.5 h-1.5 rounded-full bg-emerald-300 shadow-glow"></div>
							<span class="text-[10px] md:text-[11px] font-mono font-bold text-slate-700 dark:text-slate-200 uppercase tracking-[0.15em] whitespace-nowrap">AI Agents</span>
						</div>
					</div>
					<div
						class="orbit-item"
						style="transform: rotateY(300deg) translateZ(var(--orbit-radius));"
					>
						<div
							class="orbit-content flex items-center gap-2 px-3 py-1.5 md:px-5 md:py-2.5 rounded-full bg-white/70 dark:bg-slate-900/70 backdrop-blur-md border border-slate-200/50 dark:border-slate-700/50 transition-colors"
							style="animation-delay: -4s;"
						>
							<div class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-glow"></div>
							<span class="text-[10px] md:text-[11px] font-mono font-bold text-slate-700 dark:text-slate-200 uppercase tracking-[0.15em] whitespace-nowrap">Google Ads</span>
						</div>
					</div>
				</div>
			</div>

			<!-- CTA Buttons -->
			<div
				class="flex-none flex flex-col sm:flex-row gap-3 sm:gap-6 w-full sm:w-auto px-8 sm:px-0 pt-2 pb-2 md:pb-0 z-40"
			>
				<a
					id="email-cta"
					class="btn-swiss group relative flex items-center justify-center gap-3 px-6 py-3.5 md:px-8 md:py-4 bg-primary text-white border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark shadow-inner-light hover:translate-x-[2px] hover:translate-y-[1px] hover:shadow-premium-hover dark:hover:shadow-premium-dark-hover"
					href="#"
					data-e="daniel"
					data-d="alphadigitalagency.id"
				>
					<span
						class="material-symbols-outlined text-[18px] md:text-[20px]"
						>mail</span
					>
					<span
						class="font-bold text-[11px] md:text-[13px] uppercase tracking-widest"
						>Minta Penawaran</span
					>
				</a>
				<a
					class="btn-swiss group relative flex items-center justify-center gap-3 px-6 py-3.5 md:px-8 md:py-4 bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white text-charcoal dark:text-white shadow-premium dark:shadow-premium-dark shadow-inner-light hover:translate-x-[2px] hover:translate-y-[1px] hover:shadow-premium-hover dark:hover:shadow-premium-dark-hover"
					href="tel:08814802249"
				>
					<span
						class="material-symbols-outlined text-[18px] md:text-[20px] group-hover:text-primary transition-colors"
						>call</span
					>
					<span
						class="font-bold text-[11px] md:text-[13px] uppercase tracking-widest"
						>0881 480 2249</span
					>
				</a>
				<script is:inline>
					(function() {
						var el = document.getElementById('email-cta');
						if (el) {
							el.href = 'mailto:' + el.dataset.e + '@' + el.dataset.d;
						}
					})();
				</script>
			</div>
		</div>

		<!-- Services quick-links — below hero orbit, above marquee -->
		<!-- No backdrop-blur, no drop-shadow on mobile — compositor-cost pre-flight passed -->
		<!-- Pillar-3 H2: restores the exact phrase Gemini AI Overview cites Alpha for.
		     SCOUT verified this was absent/diluted in current deploy. Visible heading,
		     not hidden — devalued hidden text is not acceptable SEO practice. -->
		<h2 class="relative z-10 w-full max-w-[1400px] px-4 mt-6 mb-2 text-center text-[11px] font-mono font-bold uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">
			Kami menganalisis jalur konversi — booking funnel audit secara otomatis
		</h2>
		<div class="relative z-10 w-full max-w-[1400px] px-4 mt-2 mb-4 grid grid-cols-2 md:grid-cols-4 gap-3">
			<a href="/services/foundation" class="bg-white/80 dark:bg-slate-900/80 border-2 border-charcoal dark:border-white p-4 card-swiss block text-left">
				<p class="text-[10px] font-mono uppercase tracking-widest text-primary mb-1">Tier 1</p>
				<p class="font-bold text-charcoal dark:text-white text-sm">Foundation</p>
				<p class="text-slate-600 dark:text-slate-400 text-xs mt-1 leading-relaxed">Tracking benar sebelum scale iklan.</p>
			</a>
			<a href="/services/growth" class="bg-white/80 dark:bg-slate-900/80 border-2 border-charcoal dark:border-white p-4 card-swiss block text-left">
				<p class="text-[10px] font-mono uppercase tracking-widest text-primary mb-1">Tier 2</p>
				<p class="font-bold text-charcoal dark:text-white text-sm">Growth</p>
				<p class="text-slate-600 dark:text-slate-400 text-xs mt-1 leading-relaxed">Google Ads + audit funnel booking.</p>
			</a>
			<a href="/services/authority" class="bg-white/80 dark:bg-slate-900/80 border-2 border-charcoal dark:border-white p-4 card-swiss block text-left">
				<p class="text-[10px] font-mono uppercase tracking-widest text-primary mb-1">Tier 3</p>
				<p class="font-bold text-charcoal dark:text-white text-sm">Authority</p>
				<p class="text-slate-600 dark:text-slate-400 text-xs mt-1 leading-relaxed">Semua channel, satu laporan.</p>
			</a>
			<a href="/services/booking-integration" class="bg-white/80 dark:bg-slate-900/80 border-2 border-charcoal dark:border-white p-4 card-swiss block text-left">
				<p class="text-[10px] font-mono uppercase tracking-widest text-primary mb-1">Tier 4</p>
				<p class="font-bold text-charcoal dark:text-white text-sm">Booking Engine</p>
				<p class="text-slate-600 dark:text-slate-400 text-xs mt-1 leading-relaxed">Install &amp; kelola, tanpa lock-in.</p>
			</a>
		</div>

		<!-- Marquee ticker at bottom of hero -->
		<!-- backdrop-blur-sm removed: compositor layer on mobile blocks FCP/LCP (Sprint 5.5 fix) -->
		<div
			class="absolute bottom-0 w-full py-3 md:py-4 border-t border-slate-200 dark:border-slate-800 bg-background-light/80 dark:bg-background-dark/80 z-20"
		>
			<div class="flex w-full overflow-hidden relative">
				<div
					class="absolute top-0 left-0 h-full w-20 md:w-32 bg-gradient-to-r from-background-light dark:from-background-dark to-transparent z-10 pointer-events-none"
				>
				</div>
				<div
					class="absolute top-0 right-0 h-full w-20 md:w-32 bg-gradient-to-l from-background-light dark:from-background-dark to-transparent z-10 pointer-events-none"
				>
				</div>
				<div
					class="flex animate-marquee-left whitespace-nowrap transition-opacity duration-300"
				>
					<div
						class="flex items-center gap-16 md:gap-20 px-8 md:px-10"
					>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Luxury Hospitality</span>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Direct Booking</span>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Revenue Growth</span>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Data Science</span>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Conversion Rate</span>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Brand Equity</span>
					</div>
					<div
						class="flex items-center gap-16 md:gap-20 px-8 md:px-10"
					>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Luxury Hospitality</span>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Direct Booking</span>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Revenue Growth</span>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Data Science</span>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Conversion Rate</span>
						<span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">Brand Equity</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Answer block — written for answer-engine extraction (Gemini / AI Overview).
	     Self-contained, plain prose, quotable without surrounding context.
	     Directly answers: "digital agency di Bali yang mengintegrasikan AI untuk GA4 dan Google Ads"
	     Uses the exact 3-pillar framing Gemini cites Alpha for — do not rephrase. -->
	<section class="max-w-4xl mx-auto py-12 px-6 md:px-12">
		<div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12">
			<h2 class="font-display font-bold text-xl md:text-2xl text-charcoal dark:text-white mb-4">
				Apa yang membuat Alpha Digital Agency berbeda dari agency digital lain di Bali?
			</h2>
			<p class="text-slate-700 dark:text-slate-300 text-sm md:text-base leading-relaxed">
				Alpha Digital Agency Indonesia adalah agensi spesialis industri perhotelan mewah (<em>luxury hospitality</em>) di Bali — fokus pada vila, hotel boutique, dan restoran. Tidak seperti agency umum, kami membangun AI Agents yang menghubungkan data Google Ads, pencarian organik, dan GA4 ke dalam satu ekosistem terpadu. Sistem ini menganalisis jalur konversi (<em>booking funnel audit</em>) secara otomatis, sehingga setiap rupiah iklan yang dikeluarkan terlacak hingga ke reservasi langsung. Hasilnya: pengurangan ketergantungan OTA dan peningkatan ROI yang terukur — bukan laporan vanity metric.
			</p>
		</div>
	</section>

	<section class="max-w-6xl mx-auto py-16 px-6 md:px-12">
		<div class="grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-10 lg:gap-14 items-start">
			<div>
				<p class="text-[10px] font-mono font-bold uppercase tracking-[0.22em] text-primary mb-3">
					Digital Marketing Agency Bali
				</p>
				<h2 class="font-display font-bold text-3xl md:text-4xl text-charcoal dark:text-white leading-tight mb-5">
					Digital Marketing Agency Bali for Hospitality Businesses
				</h2>
				<div class="space-y-4 text-slate-700 dark:text-slate-300 text-sm md:text-base leading-relaxed">
					<p>
						Banyak bisnis mencari <strong>digital marketing Bali</strong> karena butuh website, iklan, konten, atau SEO. Untuk hotel, vila, dan restoran, masalahnya lebih spesifik: traffic harus berubah menjadi reservasi langsung, data iklan harus tersambung ke booking engine, dan laporan harus menunjukkan channel mana yang benar-benar menghasilkan revenue.
					</p>
					<p>
