---
export const prerender = true;
import SwissLayout from "../components/SwissLayout.astro";
import { WA_JASA } from "../lib/linkbio";

// Unique build string for post-deploy curl-grep verification (raw HTTP, not WebFetch)
const BUILD_TAG = "layanan-v1-2026-06-02";

// 4 service cards — outcome language, no infra leak. (Layanan spesifik final menunggu Daniel.)
const services = [
  {
    title: "Google Ads",
    desc: "Kelola & optimasi iklan biar tiap rupiah terukur dan terarah ke hasil.",
    icon: "ads_click",
  },
  {
    title: "Tracking & Konversi",
    desc: "Pasang & rapikan GA4/GTM, biar tahu mana yang menghasilkan — bukan nebak.",
    icon: "monitoring",
  },
  {
    title: "SEO & Kehadiran Online",
    desc: "Bantu bisnis lebih gampang ditemukan di Google saat orang nyari.",
    icon: "travel_explore",
  },
  {
    title: "Pendampingan / Konsultasi",
    desc: "Strategi digital marketing yang nyetel ke bisnis kamu — bukan template.",
    icon: "handshake",
  },
];

const breadcrumbLD = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://alphadigitalagency.id/" },
    { "@type": "ListItem", position: 2, name: "Layanan", item: "https://alphadigitalagency.id/layanan/" },
  ],
};
---

<SwissLayout
  title="Jasa Digital Marketing — Alpha Digital, Bali"
  description="Jasa digital marketing di Bali untuk Google Ads, tracking GA4/GTM, SEO, dan strategi pertumbuhan terukur bersama Alpha Digital."
  currentPage="layanan"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD)} />
    <!-- build:{BUILD_TAG} -->
  </Fragment>

  <!-- ===================== HERO ===================== -->
  <section class="max-w-2xl mx-auto px-6 md:px-12 mb-12 text-center" data-build={BUILD_TAG}>
    <p class="text-xs font-mono uppercase tracking-widest text-primary mb-4">
      Jasa Agensi · Bali
    </p>
    <h1 class="font-display font-extrabold text-charcoal dark:text-white leading-display tracking-tightest text-[1.9rem] sm:text-[2.5rem] md:text-[3rem]">
      Jasa Digital Marketing<span class="text-primary">.</span>
    </h1>
    <h2 class="mt-2 font-display font-bold text-base md:text-lg text-charcoal dark:text-white">
      Alpha Digital, Bali
    </h2>
    <p class="mt-4 text-sm md:text-base text-slate-600 dark:text-slate-400 font-medium leading-relaxed max-w-lg mx-auto">
      Fokus Google Ads &amp; pertumbuhan terukur. 9 tahun ngerjain akun beneran, bukan teori.
    </p>
  </section>

  <!-- ===================== KARTU LAYANAN ===================== -->
  <!-- HARD GATE: NO per-card accent tab/bar/dot; shadow-premium = down-right directional. -->
  <section class="max-w-2xl mx-auto px-6 md:px-12 mb-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {services.map((s) => (
        <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-6">
          <span class="material-symbols-outlined text-primary text-[30px]">{s.icon}</span>
          <h3 class="font-bold text-charcoal dark:text-white text-base mt-3 mb-1.5">{s.title}</h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===================== BUKTI & HASIL (folded in) ===================== -->
  <section class="max-w-2xl mx-auto px-6 md:px-12 mb-12">
    <h2 class="font-display font-bold text-xl md:text-2xl text-charcoal dark:text-white mb-6 text-center">
      Bukti &amp; Hasil
    </h2>
    <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-5 text-center max-w-lg mx-auto">
      Hasil kerja nyata — nama klien dianonimkan demi privasi.
    </p>
    <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-7 md:p-9">
      <blockquote class="border-l-4 border-primary pl-5 py-1 mb-6">
        <p class="text-slate-700 dark:text-slate-300 text-sm md:text-base leading-relaxed italic mb-2">
          "Properti vila Bali dengan 4 unit — direct booking naik 34% dalam 90 hari setelah audit funnel + optimasi Google Ads."
        </p>
        <cite class="text-xs font-mono uppercase tracking-widest text-slate-500 dark:text-slate-400 not-italic">
          — Data klien terverifikasi. Nama dirahasiakan sesuai kebijakan klien.
        </cite>
      </blockquote>
      <blockquote class="border-l-4 border-primary pl-5 py-1">
        <p class="text-slate-700 dark:text-slate-300 text-sm md:text-base leading-relaxed italic mb-2">
          "Akun iklan yang tadinya boncos jadi terukur &amp; profitable setelah dibenahi struktur &amp; trackingnya."
        </p>
        <cite class="text-xs font-mono uppercase tracking-widest text-slate-500 dark:text-slate-400 not-italic">
          — Hasil kerja agensi. Nama klien dirahasiakan demi privasi.
        </cite>
      </blockquote>
      <p class="text-slate-500 dark:text-slate-400 text-xs mt-6">
        Hasil tiap bisnis beda-beda. Kami tunjukkan metodologi lengkap saat ngobrol langsung.
      </p>
    </div>
  </section>

  <!-- ===================== CTA KONSULTASI ===================== -->
  <section class="max-w-2xl mx-auto px-6 md:px-12 mb-4 text-center">
    <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-7 md:p-9">
      <h2 class="font-display font-bold text-xl md:text-2xl text-charcoal dark:text-white mb-3">
        Mulai dari Mana?
      </h2>
      <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-7 max-w-lg mx-auto">
        Ceritakan situasi digital bisnis kamu. Kita mulai dari ngobrol — tanpa komitmen.
      </p>
      <div class="flex justify-center">
        <a
          href={WA_JASA}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-swiss inline-flex items-center justify-center gap-2 px-7 py-3.5 min-h-[52px] bg-primary text-white border-2 border-charcoal shadow-premium font-bold text-sm uppercase tracking-widest"
        >
          <span class="material-symbols-outlined">chat</span>
          Konsultasi via WhatsApp
        </a>
      </div>
    </div>
  </section>
</SwissLayout>
