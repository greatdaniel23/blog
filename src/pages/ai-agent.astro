---
export const prerender = true;
import SwissLayout from "../components/SwissLayout.astro";

const faqItems = [
  {
    q: "Apa yang dimaksud AI Agent untuk hotel atau vila?",
    a: "AI Agent adalah asisten chat cerdas yang dipasang di website properti Anda. Dilatih dari data vila Anda sendiri — kebijakan, kamar, tarif, dan layanan — sehingga bisa menjawab pertanyaan tamu secara instan, 24 jam sehari, dan mengarahkan mereka ke direct booking."
  },
  {
    q: "Apakah AI Agent menggantikan tim front desk?",
    a: "Tidak. AI Agent menangani pertanyaan berulang (ketersediaan, tarif, kebijakan, rekomendasi lokal) di luar jam kerja. Tim Anda fokus pada interaksi tamu bernilai tinggi dan layanan langsung."
  },
  {
    q: "Bahasa apa yang didukung AI Agent?",
    a: "Agent merespons secara otomatis dalam bahasa tamu — Bahasa Indonesia, Inggris, Mandarin, Jepang, dan lebih banyak lagi. Tidak perlu setup manual per bahasa."
  },
  {
    q: "Apakah AI Agent bisa terhubung ke booking engine kami?",
    a: "Ya. Kami integrasikan agent langsung ke booking engine Anda sehingga tamu bisa cek ketersediaan dan diarahkan untuk booking langsung — tanpa keterlibatan OTA."
  },
  {
    q: "Berapa lama proses setup?",
    a: "Timeline disesuaikan dengan kompleksitas data dan sistem properti Anda. Kami menangani training, integrasi, testing, dan handover sebelum go-live — jadwal pasti dikonfirmasi setelah scope awal disepakati."
  },
  {
    q: "Bagaimana AI Agent dilatih dengan data properti kami?",
    a: "AI Agent kami dilatih dari Google Place ID dan database properti Anda — rekomendasi kamar berbasis ketersediaan nyata, bukan template generik. Tamu mendapat informasi akurat yang spesifik untuk properti Anda, bukan jawaban copy-paste dari agen lain."
  }
];

const serviceLD = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "AI Agent untuk Hotel dan Vila Bali",
  "provider": {
    "@type": "Organization",
    "name": "Alpha Digital Agency",
    "url": "https://alphadigitalagency.id"
  },
  "author": {
    "@type": "Person",
    "name": "Daniel Santoso",
    "url": "https://alphadigitalagency.id/daniel-santoso/#person"
  },
  "serviceType": "AI Chatbot for Hospitality",
  "areaServed": "Bali, Indonesia",
  "description": "AI Agent yang dilatih khusus untuk properti Anda — jawab pertanyaan tamu 24/7, rekomendasikan kamar dari booking engine, terintegrasi Google Analytics. Tersedia untuk vila dan hotel di Bali.",
  "url": "https://alphadigitalagency.id/ai-agent/"
};

const faqLD = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};

const breadcrumbLD = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://alphadigitalagency.id/" },
    { "@type": "ListItem", "position": 2, "name": "AI Agent", "item": "https://alphadigitalagency.id/ai-agent/" }
  ]
};
---

<SwissLayout
  title="AI Agent for Bali Hotels | Alpha Digital"
  description="AI agent for Bali hotels and villas: answer guest questions 24/7, recommend rooms from property data, and connect inquiries to direct booking paths."
  currentPage="ai-agent"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(serviceLD)} />
        <script type="application/ld+json" set:html={JSON.stringify(faqLD)} />
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD)} />
    </Fragment>

    <!-- Hero -->
    <section class="max-w-4xl mx-auto mb-12 px-6 md:px-12 text-center">
        <p class="text-xs font-mono uppercase tracking-widest text-primary mb-4">AI Agent untuk Properti</p>
        <h1
            class="font-display font-extrabold text-charcoal dark:text-white leading-display tracking-tightest"
        >
            <span class="text-[2rem] sm:text-[3rem] md:text-[4rem] lg:text-[5rem] mb-6 block">
                AI Agent untuk Properti Anda — Aktif 24 Jam, Terintegrasi Booking Engine<span class="text-primary">.</span>
            </span>
        </h1>
        <p class="mt-4 md:mt-6 text-sm md:text-base text-slate-600 dark:text-slate-400 font-medium max-w-2xl mx-auto leading-relaxed tracking-wide">
            Asisten digital yang dilatih dari data properti Anda sendiri — menjawab pertanyaan tamu secara instan, mengarahkan ke reservasi langsung, dan bekerja saat tim Anda tidak ada.
        </p>

        <!-- CTA -->
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
            <a
                href="/ai-agent/demo/"
                class="btn-swiss inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary text-white border-2 border-charcoal shadow-premium font-bold text-sm uppercase tracking-widest"
            >
                <span class="material-symbols-outlined">chat</span>
                Coba Live Demo
            </a>
            <a
                href="https://wa.me/628814802249"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-swiss inline-flex items-center justify-center gap-2 px-6 py-3 bg-white dark:bg-slate-900 text-charcoal dark:text-white border-2 border-charcoal dark:border-white shadow-premium font-bold text-sm uppercase tracking-widest"
            >
                <span class="material-symbols-outlined">chat</span>
                WhatsApp
            </a>
        </div>
    </section>

    <section class="max-w-4xl mx-auto pb-10 px-6 md:px-12">

        <!-- Apa yang Dilakukan AI Agent -->
        <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12 mb-8">
            <h2 class="font-display font-bold text-2xl md:text-3xl text-charcoal dark:text-white mb-6">
                Apa yang Dilakukan AI Agent?
            </h2>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                AI Agent kami adalah asisten chat yang dipasang langsung di website properti Anda. Dilatih dari data vila Anda — kamar, tarif, kebijakan, dan layanan — sehingga menjawab pertanyaan tamu secara akurat dan natural.
            </p>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                Tidak ada lagi pertanyaan tamu yang tidak dijawab di luar jam kerja. Agent menangani segalanya — dari ketersediaan kamar dan harga hingga rekomendasi lokal dan panduan reservasi. Dibangun khusus untuk properti hospitality di Bali, terintegrasi dengan GA4 Analytics dan didukung data nyata properti Anda.
            </p>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
                Yang membedakan: AI Agent kami dilatih dari <strong class="text-charcoal dark:text-white">Google Place ID dan database properti Anda</strong> — rekomendasi kamar berbasis ketersediaan nyata, bukan template. Tamu mendapat informasi akurat yang benar-benar relevan untuk properti Anda.
            </p>
        </div>

        <!-- Feature Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-6">
                <div class="flex items-center gap-3 mb-3">
                    <span class="material-symbols-outlined text-primary text-3xl">schedule</span>
                    <h3 class="font-display font-bold text-lg text-charcoal dark:text-white">Aktif 24 Jam</h3>
                </div>
                <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                    Selalu siap, bahkan saat tim Anda istirahat. Tamu mendapat respons instan pukul 2 pagi sama seperti pukul 12 siang.
                </p>
            </div>

            <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-6">
                <div class="flex items-center gap-3 mb-3">
                    <span class="material-symbols-outlined text-primary text-3xl">hotel</span>
                    <h3 class="font-display font-bold text-lg text-charcoal dark:text-white">Dilatih Data Properti Anda</h3>
                </div>
                <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                    Dilatih dari kamar, tarif, amenitas, dan kebijakan properti Anda sendiri — bukan data hotel generik.
                </p>
            </div>

            <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-6">
                <div class="flex items-center gap-3 mb-3">
                    <span class="material-symbols-outlined text-primary text-3xl">translate</span>
                    <h3 class="font-display font-bold text-lg text-charcoal dark:text-white">Multibahasa Otomatis</h3>
                </div>
                <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                    Merespons dalam bahasa tamu — Indonesia, Inggris, Mandarin, Jepang, dan lebih banyak lagi, secara otomatis.
                </p>
            </div>

            <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-6">
                <div class="flex items-center gap-3 mb-3">
                    <span class="material-symbols-outlined text-primary text-3xl">trending_up</span>
                    <h3 class="font-display font-bold text-lg text-charcoal dark:text-white">Mendorong Direct Booking</h3>
                </div>
                <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                    Mengarahkan tamu ke booking langsung, mengurangi komisi OTA, dan meningkatkan pendapatan per reservasi.
                </p>
            </div>
        </div>

        <!-- Bagaimana AI Agent Membantu Reservasi Langsung -->
        <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12 mb-8">
            <h2 class="font-display font-bold text-2xl md:text-3xl text-charcoal dark:text-white mb-6">
                Bagaimana AI Agent Membantu Reservasi Langsung
            </h2>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                Tamu yang ragu tidak booking. Pertanyaan seperti "apakah kamarnya masih tersedia tanggal X?", "berapa rate untuk 3 malam?", atau "ada kolam renang privat tidak?" — kalau tidak dijawab cepat, tamu pergi ke OTA.
            </p>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                AI Agent kami menangkap momen itu. Jawaban instan, akurat, dalam bahasa tamu — diikuti dengan tautan langsung ke booking engine Anda. Tidak ada OTA yang terlibat, tidak ada komisi yang keluar.
            </p>
            <div class="bg-primary/5 dark:bg-primary/10 border-l-4 border-primary p-4 mt-4">
                <p class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed">
                    Setiap percakapan tamu direkam dan terintegrasi ke GA4 Analytics — Anda bisa melihat pertanyaan apa yang paling sering ditanyakan, tamu dari mana yang paling banyak konversi, dan di titik mana mereka berhenti sebelum booking.
                </p>
            </div>
        </div>

        <!-- Terintegrasi dengan Booking Engine -->
        <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12 mb-8">
            <h2 class="font-display font-bold text-2xl md:text-3xl text-charcoal dark:text-white mb-6">
                Terintegrasi dengan Booking Engine Anda
            </h2>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                AI Agent terhubung langsung ke sistem booking Anda — Cloudbeds, SiteMinder, Little Hotelier, STAAH, atau booking engine Alpha sendiri. Tamu bisa cek ketersediaan real-time dan langsung diarahkan untuk booking.
            </p>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
                Tidak ada lag, tidak ada informasi usang, tidak ada "hubungi kami untuk cek ketersediaan" yang membunuh konversi. Data kamar yang ditampilkan AI Agent adalah data ketersediaan nyata dari sistem Anda.
            </p>
        </div>

        <!-- Cara Kerja (How it works) -->
        <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12 mb-8">
            <h2 class="font-display font-bold text-2xl md:text-3xl text-charcoal dark:text-white mb-8">
                Setup dan Cara Kerja
            </h2>
            <div class="space-y-6">
                {[
                    { step: "01", title: "Training dari Data Properti Anda", desc: "Kami training AI Agent dari Google Place ID, database kamar, tarif, dan kebijakan properti Anda. Bukan template — data Anda yang mengajarkan." },
                    { step: "02", title: "Integrasi ke Website dan Booking Engine", desc: "Agent dipasang di website properti Anda dan terhubung ke booking engine — tamu bisa cek ketersediaan dan booking langsung dari chat." },
                    { step: "03", title: "Tamu Bertanya, Agent Menjawab", desc: "Widget chat muncul di website. Tamu klik, mulai percakapan, dan agent merespons akurat dalam bahasa mereka — dalam hitungan detik." },
                    { step: "04", title: "Data Mengalir ke GA4", desc: "Setiap percakapan direkam. Anda review log, lihat pertanyaan tamu yang paling sering, dan optimalkan konten properti berdasarkan data nyata." },
                ].map(({ step, title, desc }) => (
                    <div class="flex gap-6 items-start">
                        <div class="font-display font-extrabold text-3xl text-primary min-w-[3rem]">{step}</div>
                        <div>
                            <h3 class="font-bold text-charcoal dark:text-white mb-1">{title}</h3>
                            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Bahasa yang Didukung -->
        <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12 mb-8">
            <h2 class="font-display font-bold text-xl md:text-2xl text-charcoal dark:text-white mb-4">
                Bahasa yang Didukung
            </h2>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
                Tamu Bali datang dari seluruh dunia. AI Agent mendeteksi bahasa tamu secara otomatis dan merespons dalam bahasa yang sama — tanpa perlu konfigurasi per bahasa.
            </p>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mt-4">
                {["Bahasa Indonesia", "English", "Mandarin (中文)", "Japanese (日本語)", "German (Deutsch)", "French (Français)"].map(lang => (
                    <div class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></div>
                        <span class="text-slate-600 dark:text-slate-400 text-sm">{lang}</span>
                    </div>
                ))}
            </div>
        </div>

        <!-- CTA block -->
        <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12 text-center mb-8">
            <h2 class="font-display font-bold text-2xl md:text-3xl text-charcoal dark:text-white mb-4">
                Ingin AI Agent untuk Properti Anda?
            </h2>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-8 max-w-lg mx-auto">
                Kami bangun dan deploy AI Agent khusus untuk hotel dan vila di Bali. Hubungi kami untuk lihat apa yang bisa dilakukan untuk properti Anda.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a
                    href="mailto:daniel@alphadigitalagency.id"
                    class="btn-swiss inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary text-white border-2 border-charcoal shadow-premium font-bold text-sm uppercase tracking-widest"
                >
                    <span class="material-symbols-outlined">mail</span>
                    Minta Penawaran
                </a>
                <a
                    href="https://wa.me/628814802249"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-swiss inline-flex items-center justify-center gap-2 px-6 py-3 bg-white dark:bg-slate-900 text-charcoal dark:text-white border-2 border-charcoal dark:border-white shadow-premium font-bold text-sm uppercase tracking-widest"
                >
                    <span class="material-symbols-outlined">chat</span>
                    WhatsApp
                </a>
            </div>
        </div>

        <!-- Pertanyaan tentang AI Agent (FAQ) -->
        <div class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-8 md:p-12 mb-8">
            <h2 class="font-display font-bold text-2xl md:text-3xl text-charcoal dark:text-white mb-8">
                Pertanyaan tentang AI Agent
            </h2>
            <div class="space-y-6">
                {faqItems.map((item) => (
                    <div class="border-b border-slate-200 dark:border-slate-700 pb-6 last:border-0 last:pb-0">
                        <h3 class="font-bold text-charcoal dark:text-white mb-2">{item.q}</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{item.a}</p>
                    </div>
                ))}
            </div>
        </div>

        <!-- Internal links to service pages -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <a href="/" class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-6 card-swiss block">
                <p class="text-xs font-mono uppercase tracking-widest text-primary mb-1">Main System</p>
                <p class="font-bold text-charcoal dark:text-white">Digital Marketing Agency Bali →</p>
                <p class="text-slate-600 dark:text-slate-400 text-sm mt-1">AI Agent sebagai bagian dari sistem direct booking hospitality.</p>
            </a>
            <a href="/services/authority" class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-6 card-swiss block">
                <p class="text-xs font-mono uppercase tracking-widest text-primary mb-1">Full-Funnel Service</p>
                <p class="font-bold text-charcoal dark:text-white">Authority Tier →</p>
                <p class="text-slate-600 dark:text-slate-400 text-sm mt-1">Semua channel terhubung, termasuk integrasi AI Agent.</p>
            </a>
            <a href="/services/booking-integration" class="bg-white dark:bg-slate-900 border-2 border-charcoal dark:border-white shadow-premium dark:shadow-premium-dark p-6 card-swiss block">
                <p class="text-xs font-mono uppercase tracking-widest text-primary mb-1">Booking Engine</p>
                <p class="font-bold text-charcoal dark:text-white">Booking Integration →</p>
                <p class="text-slate-600 dark:text-slate-400 text-sm mt-1">Install booking engine yang terhubung langsung ke AI Agent Anda.</p>
            </a>
        </div>

        <!-- Author byline -->
        <p class="text-xs text-slate-500 dark:text-slate-400 mb-8">
            Ditulis oleh <a href="/daniel-santoso/" class="underline hover:text-primary">Daniel Santoso</a> · Terakhir diperbarui: Mei 2026
        </p>
    </section>
</SwissLayout>
