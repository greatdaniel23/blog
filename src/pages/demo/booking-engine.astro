---
import "../../styles/global.css";
import SwissHeader from "../../components/SwissHeader.astro";
import SwissFooter from "../../components/SwissFooter.astro";

const SITE_URL = "https://alphadigitalagency.id";
const DEFAULT_IMAGE = `${SITE_URL}/images/og-alpha-default.png`;

const orgLD = { "@context":"https://schema.org","@type":"Organization","@id":`${SITE_URL}/#organization`,"name":"Alpha Digital Agency Indonesia","url":SITE_URL,"logo":DEFAULT_IMAGE };
const webLD = { "@context":"https://schema.org","@type":"WebSite","@id":`${SITE_URL}/#website`,"url":SITE_URL,"name":"Alpha Digital Agency Indonesia","publisher":{"@id":`${SITE_URL}/#organization`} };
const breadLD = { "@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{ "@type":"ListItem","position":1,"name":"Home","item":SITE_URL },{ "@type":"ListItem","position":2,"name":"Demo Booking Engine","item":`${SITE_URL}/demo/booking-engine` }] };
---

<!doctype html>
<html class="light" lang="id">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Coba Direct Booking Engine — Alpha Digital Agency</title>
    <meta name="description" content="Coba sendiri booking engine untuk villa. Real-time availability, zero komisi OTA. Ini bukan screenshot — ini sistem produksi yang live." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://alphadigitalagency.id/demo/booking-engine" />
    <meta property="og:title" content="Coba Direct Booking Engine — Alpha Digital Agency" />
    <meta property="og:description" content="Coba sendiri booking engine untuk villa. Real-time availability, zero komisi OTA." />
    <meta property="og:url" content="https://alphadigitalagency.id/demo/booking-engine" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Alpha Digital Agency Indonesia" />
    <meta property="og:image" content={DEFAULT_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Coba Direct Booking Engine — Alpha Digital Agency" />
    <meta name="twitter:description" content="Coba sendiri booking engine untuk villa. Real-time availability, zero komisi OTA." />
    <meta name="twitter:image" content={DEFAULT_IMAGE} />
    <script type="application/ld+json" set:html={JSON.stringify(orgLD)} />
    <script type="application/ld+json" set:html={JSON.stringify(webLD)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadLD)} />
    <style is:inline>
        .dot-pattern { background-image: radial-gradient(#cbd5e1 1px, transparent 1px); background-size: 24px 24px; }
        .dark .dot-pattern { background-image: radial-gradient(#1f2937 1px, transparent 1px); }
        .browser-chrome { background: #1e293b; border-radius: 6px 6px 0 0; }
        .step-num { width: 36px; height: 36px; background: #ecfdf5; color: #059669; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 16px; flex-shrink: 0; }
        body { min-height: max(884px, 100dvh); }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-emerald-dark dark:text-gray-100 overflow-x-hidden">
    <SwissHeader currentPage="services" />

    <div class="relative w-full min-h-screen flex flex-col lg:flex-row pt-20">
        <div class="absolute inset-0 dot-pattern opacity-40 pointer-events-none z-0"></div>

        <!-- Left: Sales Copy -->
        <div class="relative z-10 w-full lg:w-5/12 flex flex-col justify-center px-6 py-16 lg:py-12 lg:pl-16 lg:pr-8 xl:pl-24">
            <div class="max-w-xl">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-100 border border-green-200 text-emerald-800 text-xs font-bold uppercase tracking-wide mb-6">
                    <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                    LIVE DEMO
                </div>

                <h1 class="text-emerald-dark dark:text-white text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.1] tracking-tight mb-6">
                    Rasakan Direct Booking <span class="text-emerald-500 dark:text-primary">Tanpa Komisi OTA</span>
                </h1>

                <p class="text-emerald-mid dark:text-gray-300 text-lg leading-relaxed mb-6">Ini bukan screenshot. Bukan mockup. Ini booking engine produksi yang sudah live dan dipakai tamu beneran. Cari tanggal, pilih kamar, lihat harga — semuanya real-time.</p>

                <div class="flex items-center gap-2 text-sm text-emerald-800 dark:text-gray-300 mb-8">
                    <span class="material-symbols-outlined text-primary">verified</span>
                    Dipake <strong>tamu beneran</strong> setiap hari. 0% komisi OTA.
                </div>

                <!-- How it works -->
                <p class="text-xs font-bold uppercase tracking-wider text-emerald-900 dark:text-emerald-400 mb-3">Cara Kerja</p>
                <div class="space-y-3 mb-8">
                    <div class="flex items-start gap-3"><div class="step-num">01</div><div><strong class="block text-sm text-emerald-900 dark:text-white">Cari tanggal</strong><span class="text-xs text-gray-500">Pilih check-in dan check-out di kalender.</span></div></div>
                    <div class="flex items-start gap-3"><div class="step-num">02</div><div><strong class="block text-sm text-emerald-900 dark:text-white">Pilih kamar</strong><span class="text-xs text-gray-500">Lihat tipe kamar, harga, dan ketersediaan.</span></div></div>
                    <div class="flex items-start gap-3"><div class="step-num">03</div><div><strong class="block text-sm text-emerald-900 dark:text-white">Isi data tamu</strong><span class="text-xs text-gray-500">Nama, email, nomor telepon — simpel.</span></div></div>
                    <div class="flex items-start gap-3"><div class="step-num">04</div><div><strong class="block text-sm text-emerald-900 dark:text-white">Bayar & booking</strong><span class="text-xs text-gray-500">Payment gateway DOKU. Konfirmasi instan.</span></div></div>
                </div>

                <div class="flex flex-col gap-3">
                    <a href="https://villa.alphadigitalagency.id/reservations" target="_blank" rel="noopener" class="bg-primary hover:bg-green-400 text-emerald-dark font-bold rounded-lg px-8 py-3.5 transition-colors shadow-lg shadow-green-500/20 text-center text-lg">
                        🏨 Coba Booking Engine Sekarang →
                    </a>
                    <p class="text-xs text-gray-400 text-center">Buka di tab baru — cari tanggal, pilih kamar, lihat harga real-time.</p>
                </div>
                <div class="flex flex-wrap gap-4 mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
                    <a href="mailto:daniel@alphadigitalagency.id?subject=Booking%20Engine%20Demo" class="bg-transparent border-2 border-emerald-dark dark:border-gray-200 text-emerald-dark dark:text-gray-200 hover:bg-emerald-dark hover:text-white dark:hover:bg-white dark:hover:text-emerald-dark font-bold rounded-lg px-8 py-3 transition-colors">Mau Ini di Villa Kamu?</a>
                    <p class="text-xs text-gray-400 self-center">Konsultasi gratis — kita bahas setup untuk properti kamu.</p>
                </div>
            </div>
        </div>

        <!-- Right: Live Demo -->
        <div class="relative z-10 w-full lg:w-7/12 bg-gradient-to-br from-emerald-50 to-green-100 dark:from-gray-800 dark:to-background-dark flex items-center justify-center p-4 lg:p-8 overflow-hidden">
            <div class="w-full h-full max-h-[85vh] rounded-sm border border-gray-300 dark:border-gray-700 shadow-2xl overflow-hidden flex flex-col bg-white">
                <div class="browser-chrome h-9 flex items-center px-4 gap-2 flex-shrink-0">
                    <div class="w-3 h-3 rounded-full bg-red-400"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                    <div class="w-3 h-3 rounded-full bg-green-400"></div>
                    <div class="flex-1 text-center text-[11px] text-gray-400 font-mono tracking-wide flex items-center justify-center gap-1">
                        <span class="material-symbols-outlined text-[12px]">lock</span>
                        villa.alphadigitalagency.id/reservations
                    </div>
                </div>
                <iframe src="https://villa.alphadigitalagency.id/reservations" class="flex-1 w-full border-0 bg-white" title="Direct Booking Engine Demo" loading="lazy" sandbox="allow-scripts allow-same-origin allow-forms allow-popups"></iframe>
            </div>
        </div>
    </div>

    <div class="text-center pb-12 px-6">
        <p class="text-xs text-gray-400 max-w-lg mx-auto">⚠️ Ini bukan demo simulasi. Ini sistem produksi yang live. Jangan booking beneran kecuali kamu serius :)</p>
    </div>

    <SwissFooter />
</body>
</html>
