---
export const prerender = true;
import SwissLayout from "../../../components/SwissLayout.astro";
---

<SwissLayout title="AI Agent Demo — Alpha Digital Agency" description="Interactive AI agent demo for hotels and villas. See how our AI answers guest questions in real-time." currentPage="ai-agent">

  <section class="pt-28 md:pt-40 pb-16 px-6 max-w-2xl mx-auto text-center">
    <h1 class="text-4xl font-black tracking-tight text-emerald-dark dark:text-white mb-6">AI Agent <span class="text-primary">Demo</span></h1>
    <p class="text-lg text-emerald-mid dark:text-gray-400 mb-8">See how an AI agent handles real guest conversations — 24/7, multi-language, trained on property data.</p>
    <a href="/en/demo/ai-agent" class="bg-purple-600 hover:bg-purple-700 text-white font-bold rounded-lg px-8 py-3.5 transition-colors shadow-lg shadow-purple-500/20 inline-block">View Interactive Demo →</a>
  </section>

</SwissLayout>
