---
export const prerender = true;
import SwissLayout from "../../../components/SwissLayout.astro";
---

<SwissLayout title="AI for Parents — Alpha Digital" description="Using AI to support children's learning and activities. A practical guide for parents.">

  <section class="pt-28 md:pt-40 pb-16 px-6 max-w-2xl mx-auto">
    <h1 class="text-4xl font-black tracking-tight text-emerald-dark dark:text-white mb-6">AI for <span class="text-primary">Parents</span></h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">Using AI to support children's learning and activities. Practical tools for busy parents.</p>
    <div class="text-center"><a href="/en/contact/" class="bg-primary hover:bg-green-400 text-emerald-dark font-bold rounded-lg px-8 py-3.5 transition-colors shadow-lg shadow-green-500/20 inline-block">Inquire →</a></div>
  </section>

</SwissLayout>
