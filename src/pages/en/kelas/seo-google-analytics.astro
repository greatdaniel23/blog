---
export const prerender = true;
import SwissLayout from "../../../components/SwissLayout.astro";
---

<SwissLayout title="SEO & Google Analytics Workshop — Alpha Digital" description="Technical SEO, Google Search Console, and GA4 for Bali hospitality. From setup to actionable insights.">

  <section class="pt-28 md:pt-40 pb-16 px-6 max-w-3xl mx-auto">
    <h1 class="text-4xl md:text-5xl font-black tracking-tight text-emerald-dark dark:text-white mb-4">SEO & <span class="text-primary">Google Analytics</span></h1>
    <p class="text-lg text-emerald-mid dark:text-gray-400 mb-10">Learn how search engines see your site and how guests find you.</p>

    <div class="prose prose-emerald dark:prose-invert max-w-none space-y-6 text-emerald-mid dark:text-gray-300 leading-relaxed mb-10">
      <h2 class="text-xl font-bold text-emerald-dark dark:text-white">What You'll Learn</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {[
          { icon: 'code', title: 'Technical SEO', desc: 'Schema markup, canonical URLs, XML sitemaps, robots.txt, Core Web Vitals.' },
          { icon: 'visibility', title: 'Google Search Console', desc: 'Index coverage, keyword performance, technical alerts. What to fix first.' },
          { icon: 'bar_chart', title: 'GA4 Basics', desc: 'Reports, explorations, conversions, audiences. Find the data that matters.' },
          { icon: 'tracking', title: 'GTM Setup', desc: 'Google Tag Manager fundamentals. Tags, triggers, variables, debugging.' },
        ].map(f => (
          <div class="border border-gray-200 dark:border-gray-800 rounded-lg p-5 space-y-2">
            <span class="material-symbols-outlined text-primary text-2xl">{f.icon}</span>
            <h3 class="font-bold text-sm">{f.title}</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">{f.desc}</p>
          </div>
        ))}
      </div>

      <h2 class="text-xl font-bold text-emerald-dark dark:text-white mt-8">Who This Is For</h2>
      <ul>
        <li>Property owners who want to understand their website traffic</li>
        <li>Marketing teams setting up analytics for the first time</li>
        <li>Anyone who looks at GA4 and feels lost</li>
      </ul>
    </div>

    <div class="text-center">
      <a href="/en/contact/" class="bg-primary hover:bg-green-400 text-emerald-dark font-bold rounded-lg px-8 py-3.5 transition-colors shadow-lg shadow-green-500/20 inline-block">Register Interest →</a>
    </div>
  </section>

</SwissLayout>
