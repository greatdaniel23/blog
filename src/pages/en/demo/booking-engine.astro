---
import "../../../styles/global.css";
import SwissHeader from "../../../components/SwissHeader.astro";
import SwissFooter from "../../../components/SwissFooter.astro";

const SITE_URL = "https://alphadigitalagency.id";
const DEFAULT_IMAGE = `${SITE_URL}/images/og-alpha-default.png`;

const orgLD = { "@context":"https://schema.org","@type":"Organization","@id":`${SITE_URL}/#organization`,"name":"Alpha Digital Agency Indonesia","url":SITE_URL };
const webLD = { "@context":"https://schema.org","@type":"WebSite","@id":`${SITE_URL}/#website`,"url":SITE_URL,"name":"Alpha Digital Agency Indonesia" };
const breadLD = { "@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{ "@type":"ListItem","position":1,"name":"Home","item":`${SITE_URL}/en/` },{ "@type":"ListItem","position":2,"name":"Demo Booking Engine","item":`${SITE_URL}/en/demo/booking-engine` }] };
---

<!doctype html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Try the Direct Booking Engine — Alpha Digital Agency</title>
    <meta name="description" content="Try the villa booking engine yourself. Real-time availability, zero OTA commission. Not a screenshot — this is a live production system." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://alphadigitalagency.id/en/demo/booking-engine" />
    <link rel="alternate" hreflang="id" href="https://alphadigitalagency.id/demo/booking-engine" />
    <link rel="alternate" hreflang="en" href="https://alphadigitalagency.id/en/demo/booking-engine" />
    <meta property="og:title" content="Try the Direct Booking Engine — Alpha Digital Agency" />
    <meta property="og:description" content="Try the villa booking engine yourself. Real-time availability, zero OTA commission." />
    <meta property="og:url" content="https://alphadigitalagency.id/en/demo/booking-engine" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Alpha Digital Agency Indonesia" />
    <meta property="og:image" content={DEFAULT_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Try the Direct Booking Engine — Alpha Digital Agency" />
    <meta name="twitter:image" content={DEFAULT_IMAGE} />
    <script type="application/ld+json" set:html={JSON.stringify(orgLD)} />
    <script type="application/ld+json" set:html={JSON.stringify(webLD)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadLD)} />
    <style is:inline>
        .dot-pattern { background-image: radial-gradient(#cbd5e1 1px, transparent 1px); background-size: 24px 24px; }
        .dark .dot-pattern { background-image: radial-gradient(#1f2937 1px, transparent 1px); }
        .browser-chrome { background: #1e293b; border-radius: 6px 6px 0 0; }
        .step-num { width: 36px; height: 36px; background: #ecfdf5; color: #059669; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 16px; flex-shrink: 0; }
        body { min-height: max(884px, 100dvh); }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-emerald-dark dark:text-gray-100 overflow-x-hidden">
    <SwissHeader currentPage="services" />

    <div class="relative w-full min-h-screen flex flex-col lg:flex-row pt-20">
        <div class="absolute inset-0 dot-pattern opacity-40 pointer-events-none z-0"></div>

        <div class="relative z-10 w-full lg:w-5/12 flex flex-col justify-center px-6 py-16 lg:py-12 lg:pl-16 lg:pr-8 xl:pl-24">
            <div class="max-w-xl">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-100 border border-green-200 text-emerald-800 text-xs font-bold uppercase tracking-wide mb-6">
                    <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                    LIVE DEMO
                </div>

                <h1 class="text-emerald-dark dark:text-white text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.1] tracking-tight mb-6">
                    Experience Direct Booking <span class="text-emerald-500 dark:text-primary">Zero OTA Commission</span>
                </h1>

                <p class="text-emerald-mid dark:text-gray-300 text-lg leading-relaxed mb-6">Not a screenshot. Not a mockup. This is a production booking engine used by real guests. Search dates, pick rooms, see pricing — all real-time.</p>

                <div class="flex items-center gap-2 text-sm text-emerald-800 dark:text-gray-300 mb-8">
                    <span class="material-symbols-outlined text-primary">verified</span>
                    Used by <strong>real guests</strong> every day. 0% OTA commission.
                </div>

                <p class="text-xs font-bold uppercase tracking-wider text-emerald-900 dark:text-emerald-400 mb-3">How It Works</p>
                <div class="space-y-3 mb-8">
                    <div class="flex items-start gap-3"><div class="step-num">01</div><div><strong class="block text-sm text-emerald-900 dark:text-white">Search dates</strong><span class="text-xs text-gray-500">Pick check-in and check-out.</span></div></div>
                    <div class="flex items-start gap-3"><div class="step-num">02</div><div><strong class="block text-sm text-emerald-900 dark:text-white">Choose room</strong><span class="text-xs text-gray-500">Browse types, rates, availability.</span></div></div>
                    <div class="flex items-start gap-3"><div class="step-num">03</div><div><strong class="block text-sm text-emerald-900 dark:text-white">Enter guest info</strong><span class="text-xs text-gray-500">Name, email, phone — simple.</span></div></div>
                    <div class="flex items-start gap-3"><div class="step-num">04</div><div><strong class="block text-sm text-emerald-900 dark:text-white">Pay & book</strong><span class="text-xs text-gray-500">DOKU payment gateway. Instant confirmation.</span></div></div>
                </div>

                <div class="flex flex-col gap-3">
                    <a href="https://villa.alphadigitalagency.id/reservations" target="_blank" rel="noopener" class="bg-primary hover:bg-green-400 text-emerald-dark font-bold rounded-lg px-8 py-3.5 transition-colors shadow-lg shadow-green-500/20 text-center text-lg">
                        🏨 Try Booking Engine Now →
                    </a>
                    <p class="text-xs text-gray-400 text-center">Opens in new tab — search dates, choose rooms, see real-time pricing.</p>
                </div>
                <div class="flex flex-wrap gap-4 mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
                    <a href="mailto:daniel@alphadigitalagency.id?subject=Booking%20Engine%20Demo" class="bg-transparent border-2 border-emerald-dark dark:border-gray-200 text-emerald-dark dark:text-gray-200 hover:bg-emerald-dark hover:text-white dark:hover:bg-white dark:hover:text-emerald-dark font-bold rounded-lg px-8 py-3 transition-colors">Want This for Your Villa?</a>
                    <p class="text-xs text-gray-400 self-center">Free consultation — we'll set up a booking engine for your property.</p>
                </div>
            </div>
        </div>

        <div class="relative z-10 w-full lg:w-7/12 bg-gradient-to-br from-emerald-50 to-green-100 dark:from-gray-800 dark:to-background-dark flex items-center justify-center p-4 lg:p-8 overflow-hidden">
            <div class="w-full h-full max-h-[85vh] rounded-sm border border-gray-300 dark:border-gray-700 shadow-2xl overflow-hidden flex flex-col bg-white">
                <div class="browser-chrome h-9 flex items-center px-4 gap-2 flex-shrink-0">
                    <div class="w-3 h-3 rounded-full bg-red-400"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                    <div class="w-3 h-3 rounded-full bg-green-400"></div>
                    <div class="flex-1 text-center text-[11px] text-gray-400 font-mono tracking-wide flex items-center justify-center gap-1">
                        <span class="material-symbols-outlined text-[12px]">lock</span>
                        villa.alphadigitalagency.id/reservations
                    </div>
                </div>
                <iframe src="https://villa.alphadigitalagency.id/reservations" class="flex-1 w-full border-0 bg-white" title="Direct Booking Engine Demo" loading="lazy" sandbox="allow-scripts allow-same-origin allow-forms allow-popups"></iframe>
            </div>
        </div>
    </div>

    <div class="text-center pb-12 px-6">
        <p class="text-xs text-gray-400 max-w-lg mx-auto">⚠️ Not a simulation. This is a live production system. Please don't make real bookings unless you're serious :)</p>
    </div>

    <SwissFooter />
</body>
</html>
