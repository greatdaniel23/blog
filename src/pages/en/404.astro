---
import SwissLayout from "../../components/SwissLayout.astro";
---

<SwissLayout title="Page Not Found — Alpha Digital Agency" description="The page you're looking for doesn't exist." robots="noindex, nofollow">

  <section class="pt-28 md:pt-40 pb-16 px-6 max-w-2xl mx-auto text-center">
    <h1 class="text-7xl font-black tracking-tight text-primary mb-4">404</h1>
    <p class="text-xl text-emerald-dark dark:text-white mb-2">Page not found</p>
    <p class="text-gray-500 mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/en/" class="bg-primary hover:bg-green-400 text-emerald-dark font-bold rounded-lg px-8 py-3.5 transition-colors shadow-lg shadow-green-500/20 inline-block">Back to Home →</a>
  </section>

</SwissLayout>
