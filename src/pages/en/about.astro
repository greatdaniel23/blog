---
export const prerender = true;
import SwissLayout from "../../components/SwissLayout.astro";
---

<SwissLayout title="About Alpha Digital Agency — Bali Digital Marketing" description="Alpha Digital Agency Indonesia — Bali's first openly AI-powered digital agency. Google Ads, SEO, Direct Booking Engine, AI Agent for hotels, villas, and restaurants." currentPage="about">

  <section class="pt-28 md:pt-40 pb-16 px-6 max-w-3xl mx-auto">
    <h1 class="text-4xl md:text-5xl font-black tracking-tight text-emerald-dark dark:text-white mb-6">About <span class="text-primary">Alpha Digital</span></h1>

    <div class="prose prose-emerald dark:prose-invert max-w-none space-y-6 text-emerald-mid dark:text-gray-300 leading-relaxed">
      <p class="text-lg">Alpha Digital Agency Indonesia is a <strong>digital marketing agency based in Denpasar, Bali</strong>, specializing in Digital Transformation, Google Ads, and AI Integration for the hospitality industry.</p>

      <h2 class="text-xl font-bold text-emerald-dark dark:text-white mt-10">Our Positioning</h2>
      <p>We are the <strong>first agency in Bali to openly declare end-to-end AI/LLM usage</strong>. We don't sell tech. We don't sell platforms. We ensure digital marketing technology is implemented correctly to paint a clear picture of your villa business.</p>

      <h2 class="text-xl font-bold text-emerald-dark dark:text-white mt-10">Our Founder</h2>
      <p><strong>Daniel Santoso</strong> — 9 years of Google Ads experience, Google certified in Digital Marketing & E-Commerce and Google Ads Search. He operates as both founder and hands-on executor.</p>
      <p><a href="/en/daniel-santoso/" class="text-primary hover:underline font-bold">More about Daniel →</a></p>

      <h2 class="text-xl font-bold text-emerald-dark dark:text-white mt-10">Core Services</h2>
      <div class="grid gap-4 sm:grid-cols-2 mt-4">
        <div class="border border-gray-200 dark:border-gray-800 rounded-lg p-5">
          <span class="material-symbols-outlined text-primary text-3xl mb-2">ads_click</span>
          <h3 class="font-bold text-sm">Google Ads</h3>
          <p class="text-sm text-gray-500">LLM-enchanted campaign management. ROAS-focused optimization.</p>
        </div>
        <div class="border border-gray-200 dark:border-gray-800 rounded-lg p-5">
          <span class="material-symbols-outlined text-primary text-3xl mb-2">calendar_month</span>
          <h3 class="font-bold text-sm">Direct Booking Engine</h3>
          <p class="text-sm text-gray-500">Edge-rendered. Google Hotel Center ready. 0% OTA commission.</p>
        </div>
        <div class="border border-gray-200 dark:border-gray-800 rounded-lg p-5">
          <span class="material-symbols-outlined text-primary text-3xl mb-2">smart_toy</span>
          <h3 class="font-bold text-sm">AI Agent for Business</h3>
          <p class="text-sm text-gray-500">LLM chatbot on your website. Trained on your property data. 24/7.</p>
        </div>
        <div class="border border-gray-200 dark:border-gray-800 rounded-lg p-5">
          <span class="material-symbols-outlined text-primary text-3xl mb-2">analytics</span>
          <h3 class="font-bold text-sm">SEO & Data Tracking</h3>
          <p class="text-sm text-gray-500">GTM, GSC, GA4, Microsoft Clarity. Fundamental but done right.</p>
        </div>
      </div>

      <div class="text-center pt-10">
        <a href="/en/services/growth/" class="bg-primary hover:bg-green-400 text-emerald-dark font-bold rounded-lg px-8 py-3.5 transition-colors shadow-lg shadow-green-500/20 inline-block">Explore Our Services →</a>
      </div>
    </div>
  </section>

</SwissLayout>
