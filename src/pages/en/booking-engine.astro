---
import "../../styles/global.css";
import SwissHeader from "../../components/SwissHeader.astro";
import SwissFooter from "../../components/SwissFooter.astro";

const SITE_URL = "https://alphadigitalagency.id";
const DEFAULT_IMAGE = `${SITE_URL}/images/og-alpha-default.png`;

const orgLD = { "@context":"https://schema.org","@type":"Organization","@id":`${SITE_URL}/#organization`,"name":"Alpha Digital Agency Indonesia","url":SITE_URL,"logo":DEFAULT_IMAGE };
const webLD = { "@context":"https://schema.org","@type":"WebSite","@id":`${SITE_URL}/#website`,"url":SITE_URL,"name":"Alpha Digital Agency Indonesia" };
const serviceLD = { "@context":"https://schema.org","@type":"Service","name":"Direct Booking Engine for Villas and Hotels in Bali","provider":{"@type":"Organization","name":"Alpha Digital Agency"},"areaServed":"Bali, Indonesia","description":"Direct booking engine for Bali villas and hotels. Edge-rendered, Google Hotel Center ready, Core Web Vitals optimized." };
const breadLD = { "@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{ "@type":"ListItem","position":1,"name":"Home","item":`${SITE_URL}/en/` },{ "@type":"ListItem","position":2,"name":"Booking Engine","item":`${SITE_URL}/en/booking-engine` }] };
---

<!doctype html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Direct Booking Engine — Alpha Digital Agency Indonesia</title>
    <meta name="description" content="Direct booking engine for Bali villas and hotels. Edge-rendered, Google Hotel Center ready, Core Web Vitals optimized. Reduce OTA dependency." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://alphadigitalagency.id/en/booking-engine" />
    <link rel="alternate" hreflang="id" href="https://alphadigitalagency.id/booking-engine" />
    <link rel="alternate" hreflang="en" href="https://alphadigitalagency.id/en/booking-engine" />
    <meta property="og:title" content="Direct Booking Engine — Alpha Digital Agency Indonesia" />
    <meta property="og:description" content="Direct booking engine for Bali villas and hotels. Edge-rendered, Google Hotel Center ready." />
    <meta property="og:url" content="https://alphadigitalagency.id/en/booking-engine" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Alpha Digital Agency Indonesia" />
    <meta property="og:image" content={DEFAULT_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Direct Booking Engine — Alpha Digital Agency Indonesia" />
    <meta name="twitter:image" content={DEFAULT_IMAGE} />
    <script type="application/ld+json" set:html={JSON.stringify(orgLD)} />
    <script type="application/ld+json" set:html={JSON.stringify(webLD)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceLD)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadLD)} />
    <style is:inline>
        .dot-pattern { background-image: radial-gradient(#cbd5e1 1px, transparent 1px); background-size: 24px 24px; }
        .dark .dot-pattern { background-image: radial-gradient(#1f2937 1px, transparent 1px); }
        .step-num { width: 36px; height: 36px; background: #ecfdf5; color: #059669; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 16px; flex-shrink: 0; }
        body { min-height: max(884px, 100dvh); }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-emerald-dark dark:text-gray-100 overflow-x-hidden">
    <SwissHeader currentPage="services" />

    <div class="relative w-full min-h-screen flex flex-col lg:flex-row pt-20">
        <div class="absolute inset-0 dot-pattern opacity-40 pointer-events-none z-0"></div>
        <div class="relative z-10 w-full lg:w-1/2 flex flex-col justify-center px-6 py-24 lg:py-12 lg:pl-16 lg:pr-8 xl:pl-24">
            <div class="max-w-xl">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-100 border border-green-200 text-emerald-800 text-xs font-bold uppercase tracking-wide mb-6">
                    <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                    Google Connectivity Partner Ready
                </div>
                <h1 class="text-emerald-dark dark:text-white text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.1] tracking-tight mb-6">
                    The Direct Booking Engine <span class="text-emerald-500 dark:text-primary">Built for Speed.</span>
                </h1>
                <p class="text-emerald-mid dark:text-gray-300 text-lg sm:text-xl leading-relaxed mb-6 max-w-lg">
                    Maximize direct revenue with our powerful booking solution. Built on <strong>edge technology</strong> for lightning-fast performance, Core Web Vitals excellence, and seamless <strong>Google Hotel Center</strong> integration.
                </p>

                <div class="flex flex-col gap-3 mb-8">
                    <a href="/en/demo/booking-engine" class="bg-primary hover:bg-green-400 text-emerald-dark font-bold rounded-lg px-10 py-4 transition-colors shadow-lg shadow-green-500/20 text-center text-lg">
                        🏨 Try the Booking Engine Now →
                    </a>
                    <p class="text-xs text-gray-400 text-center">Open interactive demo — search dates, pick rooms, see real-time pricing. No screenshots.</p>
                </div>

                <div class="flex flex-wrap gap-4 mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
                    <a href="mailto:daniel@alphadigitalagency.id?subject=request%20install" class="bg-transparent border-2 border-emerald-dark dark:border-gray-200 text-emerald-dark dark:text-gray-200 hover:bg-emerald-dark hover:text-white dark:hover:bg-white dark:hover:text-emerald-dark font-bold rounded-lg px-8 py-3.5 transition-colors">
                        Request to Use
                    </a>
                </div>
            </div>
        </div>

        <div class="relative w-full lg:w-1/2 bg-gradient-to-br from-emerald-50 to-green-100 dark:from-gray-800 dark:to-background-dark flex items-center justify-center p-8 lg:p-16 overflow-hidden">
            <div class="relative w-full max-w-2xl transform lg:translate-x-12 lg:rotate-[-2deg] transition-transform duration-700 hover:rotate-0 shadow-2xl rounded-sm border border-gray-200 dark:border-gray-700 overflow-hidden bg-white">
                <div class="h-8 bg-gray-50 border-b border-gray-100 flex items-center px-4 gap-2">
                    <div class="w-2.5 h-2.5 rounded-full bg-red-400"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-yellow-400"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-green-400"></div>
                    <div class="flex-1 text-center text-[10px] font-serif tracking-widest text-gray-400 uppercase">
                        <span class="material-symbols-outlined text-[10px] align-middle mr-1">lock</span>
                        booking.villaname.com
                    </div>
                </div>
                <div class="flex flex-col items-center justify-center h-[500px] bg-gradient-to-b from-gray-50 to-white dark:from-gray-900 dark:to-gray-800 p-8 text-center space-y-6">
                    <div class="w-20 h-20 rounded-2xl bg-primary/10 flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary text-5xl">calendar_month</span>
                    </div>
                    <div class="space-y-2 max-w-sm">
                        <h3 class="font-bold text-2xl text-gray-900 dark:text-white leading-tight">Direct Booking Engine for Villas</h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">Real-time availability, zero OTA commission, integrated payment gateway. Live & in production.</p>
                    </div>
                    <div class="flex flex-wrap justify-center gap-2">
                        <span class="px-3 py-1 rounded-full bg-green-50 border border-green-100 text-green-800 text-[11px] font-medium">Real-Time Sync</span>
                        <span class="px-3 py-1 rounded-full bg-green-50 border border-green-100 text-green-800 text-[11px] font-medium">0% Commission</span>
                        <span class="px-3 py-1 rounded-full bg-green-50 border border-green-100 text-green-800 text-[11px] font-medium">DOKU Payment</span>
                        <span class="px-3 py-1 rounded-full bg-green-50 border border-green-100 text-green-800 text-[11px] font-medium">Google Hotel Center</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <SwissFooter />
</body>
</html>
