---
import BaseHead from "../components/BaseHead.astro";

const { title, description, image } = Astro.props;
---

<!doctype html>
<html class="light" lang="en">
    <head>
        <BaseHead title={title} description={description} image={image} />
        <!-- Self-hosted Manrope: preload + @font-face inline ensures font renders
             immediately without network dependency on Google Fonts. -->
        <link
            rel="preload"
            href="/fonts/manrope-latin.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <style>
            /* Inline @font-face: eliminates CSS-parse dependency for font matching.
               This @font-face is also in the global.css bundle but inlining it here
               means the browser can match the font-family declaration before the
               external CSS file arrives — prevents font swap reflow. */
            @font-face{
                font-family:'Manrope';font-style:normal;font-weight:300 800;
                font-display:optional;
                src:url('/fonts/manrope-latin.woff2') format('woff2');
                unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD
            }
            /* Earliest possible background color — prevents white flash in dark mode
               and sets correct bg before CSS bundle arrives. */
            html.light body{background-color:#f8fafc}
            html.dark body{background-color:#020617;color:#fff}
        </style>
        <!-- Material Symbols: non-blocking async load (icon font, not LCP-critical) -->
    </head>
    <body
        class="bg-background-light dark:bg-background-dark text-charcoal dark:text-white overflow-hidden h-screen flex flex-col font-body selection:bg-primary selection:text-white transition-colors duration-500"
    >
        <div
            class="fixed inset-0 z-0 opacity-[0.04] pointer-events-none mix-blend-multiply dark:mix-blend-overlay bg-noise-pattern"
        >
        </div>
        <div
            class="fixed inset-0 z-0 pointer-events-none bg-dot-grid opacity-70 mask-image-gradient"
        >
        </div>

        <slot />
    </body>
</html>
